---
import Navbar from '../components/Navbar.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props { 
  title: string; 
  description: string;
  image?: string;
  noindex?: boolean;  // [OPRAVA 6] Volitelný prop pro 404 a jiné stránky bez indexace
}

const { title, description, image = '/og-image.webp', noindex = false } = Astro.props; 
import '../styles/global.css';

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://www.lagoon-masaze.cz');
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- [OPRAVA 1] Canonical link tag – Google potřebuje tento tag, og:url nestačí -->
    <link rel="canonical" href={canonicalURL} />

    <!-- [OPRAVA 6] noindex pro 404 a jiné stránky -->
    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- [OPRAVA 4] Favicon sada -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#4A403A" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="Lagoon Masáže" />

    <!-- [OPRAVA 2] Twitter / X Card meta tagy -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, canonicalURL)} />

    <!-- [OPRAVA 3] Schema.org – přidáno aggregateRating pro rich snippety ve výsledcích -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": ["LocalBusiness", "SpaOrBeautyShop"],
        "name": "Lagoon Masáže",
        "image": "https://www.lagoon-masaze.cz/og-image.webp",
        "@id": "https://www.lagoon-masaze.cz",
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 50.4102,
          "longitude": 14.9025
        },
        "hasMap": "https://maps.app.goo.gl/pAcxyPUEK9RcHGYa9",
        "url": "https://www.lagoon-masaze.cz",
        "telephone": "+420732596212",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Staroměstské náměstí 19/23",
          "addressLocality": "Mladá Boleslav",
          "postalCode": "293 01",
          "addressCountry": "CZ"
        },
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
              "Saturday"
            ],
            "opens": "08:00",
            "closes": "20:00"
          }
        ],
        "priceRange": "$$"
      }
    </script>
    
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link
      href="https://api.fontshare.com/v2/css?f[]=cormorant@300,400,500,600&f[]=satoshi@300,400,500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="is-loading" style="margin:0">

    <!-- [OPRAVA 7] Skip-to-content link – pro uživatele klávesnice a čteček obrazovky -->
    <a href="#hero" class="skip-link">Přeskočit na obsah</a>
    
    <div id="preloader" class="preloader" role="status" aria-label="Načítání stránky">
      <div class="preloader__content">
        <!-- [OPRAVA 5] height="auto" není platná HTML hodnota – nahrazeno výškou v px -->
        <img src="/lagoon-bronze.png" alt="" class="preloader__logo" width="180" height="100" aria-hidden="true" />
        <div class="preloader__spinner"></div>
      </div>
    </div>

    <Navbar />
    <slot />
    
<script is:inline>
  window.addEventListener('load', function() {
    const preloader = document.getElementById('preloader');
    const body = document.body;

    if (preloader) {
      preloader.classList.add('is-hidden');
      body.classList.remove('is-loading');

      setTimeout(() => {
        preloader.remove();
      }, 600);
    }
  });
</script>
<CookieBanner />
  </body>
</html>

<style is:global>
  /* [OPRAVA 7] Skip-to-content link – vizuálně skrytý, zobrazí se při focusu */
  .skip-link {
    position: absolute;
    top: -100%;
    left: 1rem;
    z-index: 9999;
    padding: 0.6rem 1.2rem;
    background: var(--color-brown);
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 0 0 0.5rem 0.5rem;
    transition: top 0.2s ease;
  }
  .skip-link:focus {
    top: 0;
    outline: 3px solid var(--color-gold);
    outline-offset: 2px;
  }

  body.is-loading {
    overflow: hidden;
  }

  .preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-white);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  .preloader.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .preloader__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .preloader__logo {
    animation: pulse 2s infinite ease-in-out;
  }

  .preloader__spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(198, 162, 122, 0.2); 
    border-top-color: var(--color-gold, #C6A27A); 
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes pulse {
    0%   { transform: scale(0.95); opacity: 0.7; }
    50%  { transform: scale(1.02); opacity: 1; }
    100% { transform: scale(0.95); opacity: 0.7; }
  }

  @keyframes spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .preloader__logo {
      animation: none;
      transform: scale(1);
      opacity: 1;
    }
    .preloader__spinner {
      display: none;
      animation: none;
    }
    .preloader {
      transition: none !important;
    }
    .skip-link {
      transition: none !important;
    }
  }
</style>