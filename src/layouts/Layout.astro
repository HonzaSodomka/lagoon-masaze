---
import Navbar from '../components/Navbar.astro';
interface Props { title: string; }
const { title } = Astro.props;
import '../styles/global.css';
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link
      href="https://api.fontshare.com/v2/css?f[]=cormorant@300,400,500,600&f[]=satoshi@300,400,500&display=swap"
      rel="stylesheet"
    />
    <script src="https://unpkg.com/lucide@latest" is:inline></script>
  </head>
  <body class="is-loading" style="margin:0">
    
    <div id="preloader" class="preloader">
      <div class="preloader__content">
        <img src="/lagoon-bronze.png" alt="Lagoon Masáže načítání" class="preloader__logo" width="180" height="auto" />
        <div class="preloader__spinner"></div>
      </div>
    </div>

    <Navbar />
    <slot />
    
    <script is:inline>
      document.addEventListener('DOMContentLoaded', function () {
        if (window.lucide) window.lucide.createIcons();
      });

      // Odstranění preloaderu po načtení stránky
      window.addEventListener('load', function() {
        const preloader = document.getElementById('preloader');
        const body = document.body;

        if (preloader) {
          preloader.classList.add('is-hidden');
          body.classList.remove('is-loading');

          setTimeout(() => {
            preloader.remove();
          }, 600);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  body.is-loading {
    overflow: hidden;
  }

  .preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-white);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  .preloader.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  /* Obal pro logo a spinner, aby byly hezky pod sebou */
  .preloader__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem; /* Mezera mezi logem a spinnerem */
  }

  .preloader__logo {
    animation: pulse 2s infinite ease-in-out;
  }

  /* ── CSS SPINNER ── */
  .preloader__spinner {
    width: 36px;
    height: 36px;
    /* Poloprůhledná zlatá stopa */
    border: 3px solid rgba(198, 162, 122, 0.2); 
    /* Plná zlatá barva, která se točí */
    border-top-color: var(--color-gold, #C6A27A); 
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  /* Animace pulzování loga */
  @keyframes pulse {
    0%   { transform: scale(0.95); opacity: 0.7; }
    50%  { transform: scale(1.02); opacity: 1; }
    100% { transform: scale(0.95); opacity: 0.7; }
  }

  /* Animace točení spinneru */
  @keyframes spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }
</style>