---
import Navbar from '../components/Navbar.astro';
import CookieBanner from '../components/CookieBanner.astro';

interface Props { 
  title: string; 
  description: string;
  image?: string;
  noindex?: boolean;
  forceScrolledNavbar?: boolean;
}

const { title, description, image = '/og-image.webp', noindex = false, forceScrolledNavbar = false } = Astro.props; 
import '../styles/global.css';

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://www.lagoon-masaze.cz');
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <link rel="canonical" href={canonicalURL} />

    {noindex && <meta name="robots" content="noindex, follow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#4A403A" />

    <!-- Lokální SEO -->
    <meta name="geo.region" content="CZ-SC" />
    <meta name="geo.placename" content="Mladá Boleslav" />
    <meta name="geo.position" content="50.4102;14.9025" />
    <meta name="ICBM" content="50.4102, 14.9025" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, canonicalURL)} />
    <meta property="og:locale" content="cs_CZ" />
    <meta property="og:site_name" content="Lagoon Masáže" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, canonicalURL)} />

    <!-- Schema.org -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": ["LocalBusiness", "SpaOrBeautyShop"],
        "name": "Lagoon Masáže",
        "image": "https://www.lagoon-masaze.cz/og-image.webp",
        "@id": "https://www.lagoon-masaze.cz",
        "url": "https://www.lagoon-masaze.cz",
        "telephone": "+420732596212",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Staroměstské náměstí 19/23",
          "addressLocality": "Mladá Boleslav",
          "postalCode": "293 01",
          "addressCountry": "CZ"
        },
        "geo": {
          "@type": "GeoCoordinates",
          "latitude": 50.4102,
          "longitude": 14.9025
        },
        "hasMap": "https://maps.app.goo.gl/pAcxyPUEK9RcHGYa9",
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": [
              "Monday", "Tuesday", "Wednesday",
              "Thursday", "Friday", "Saturday"
            ],
            "opens": "08:00",
            "closes": "20:00"
          }
        ],
        "priceRange": "$$",
        "sameAs": [
          "https://www.instagram.com/lagoon_masaze",
          "https://www.facebook.com/p/Lagoon-Mas%C3%A1%C5%BEe-61553022234305/"
        ]
      }
    </script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@200;300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="preconnect" href="https://api.fontshare.com" />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@300,400,500,600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="is-loading" style="margin:0">

    <div id="preloader" class="preloader" aria-hidden="true">
      <div class="preloader__content">
        <img src="/lagoon-bronze.png" alt="" class="preloader__logo" width="180" height="100" aria-hidden="true" />
        <div class="preloader__spinner"></div>
      </div>
    </div>

    <Navbar forceScrolled={forceScrolledNavbar} />
    <main id="main-content">
      <slot />
    </main>
    
    <script is:inline>
      window.addEventListener('lagoon:video-ready', function() {
        const preloader = document.getElementById('preloader');
        const body = document.body;

        if (preloader) {
          preloader.classList.add('is-hidden');
          body.classList.remove('is-loading');

          setTimeout(() => {
            preloader.remove();
          }, 600);
        }
      }, { once: true });
    </script>

    <script>
      function initScrollAnimations() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

        document.querySelectorAll('.scroll-animate').forEach((el) => {
          observer.observe(el);
        });
      }

      document.addEventListener('astro:page-load', initScrollAnimations);
      initScrollAnimations();
    </script>

    <CookieBanner />
  </body>
</html>

<style is:global>
  body.is-loading {
    overflow: hidden;
  }

  .preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    height: 100dvh;
    background-color: var(--color-white);
    z-index: 9999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.6s ease, visibility 0.6s ease;
  }

  .preloader.is-hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
  }

  .preloader__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .preloader__logo {
    animation: pulse 2s infinite ease-in-out;
  }

  .preloader__spinner {
    width: 36px;
    height: 36px;
    border: 3px solid rgba(198, 162, 122, 0.2); 
    border-top-color: var(--color-gold, #C6A27A); 
    border-radius: 50%;
    animation: spin 1s linear infinite;
  }

  @keyframes pulse {
    0%   { transform: scale(0.95); opacity: 0.7; }
    50%  { transform: scale(1.02); opacity: 1; }
    100% { transform: scale(0.95); opacity: 0.7; }
  }

  @keyframes spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  main {
    display: contents;
  }

  @media (prefers-reduced-motion: reduce) {
    .preloader__logo {
      animation: none;
      transform: scale(1);
      opacity: 1;
    }
    .preloader__spinner {
      display: none;
      animation: none;
    }
    .preloader {
      transition: none !important;
    }
  }
</style>