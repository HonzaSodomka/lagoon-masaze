---
// src/components/Navbar.astro
const isHome = Astro.url.pathname === '/';
const p = isHome ? '' : '/';

interface Props {
  forceScrolled?: boolean;
}
const { forceScrolled = false } = Astro.props;
---

<header class="navbar" id="navbar" role="banner" data-force-scrolled={forceScrolled ? 'true' : 'false'}>
  <div class="navbar__inner">

    <a href="/" class="navbar__logo" aria-label="Zpět na hlavní stránku – Lagoon Masáže">
      <img class="navbar__logo-img navbar__logo-white" src="/logo.png" alt="" width="710" height="394" />
      <img class="navbar__logo-img navbar__logo-dark" src="/lagoon-bronze.png" alt="" width="710" height="394" aria-hidden="true" />
    </a>

    <nav class="navbar__nav" aria-label="Hlavní navigace">
      <a href={`${p}#typy-masazi`} class="navbar__link">Typy masáží</a>
      <span class="navbar__dot" aria-hidden="true">·</span>
      <a href={`${p}#darkovy-poukaz`} class="navbar__link">Dárkové poukazy</a>
      <span class="navbar__dot" aria-hidden="true">·</span>
      <a href={`${p}#nas-tym`} class="navbar__link">Naše masérky</a>
      <span class="navbar__dot" aria-hidden="true">·</span>
      <a href="/jak-to-funguje" class="navbar__link">Jak to u nás funguje</a>
      <span class="navbar__dot" aria-hidden="true">·</span>
      <a href={`${p}#kontakt`} class="navbar__link">Kde nás najdete</a>
    </nav>

    <a href="/rezervace" class="navbar__cta" aria-label="Rezervovat termín - přesun na rezervační systém">Rezervovat masáž</a>

    <button
      id="menu-toggle"
      class="navbar__hamburger"
      aria-label="Otevřít menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
    </button>

  </div>
</header>

<nav id="mobile-menu" class="mobile-menu" aria-label="Mobilní navigace" aria-hidden="true">
  <a href={`${p}#typy-masazi`} class="mobile-menu__link">Typy masáží</a>
  <a href={`${p}#darkovy-poukaz`} class="mobile-menu__link">Dárkové poukazy</a>
  <a href={`${p}#nas-tym`} class="mobile-menu__link">Naše masérky</a>
  <a href="/jak-to-funguje" class="mobile-menu__link">Jak to u nás funguje</a>
  <a href={`${p}#kontakt`} class="mobile-menu__link">Kde nás najdete</a>
  <a href="/rezervace" class="mobile-menu__cta">Rezervovat masáž</a>
</nav>

<style>
  :root {
    --nav-duration: 0.6s;
    --nav-ease: linear;
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: transparent;
    box-shadow: none;
    transition:
      background var(--nav-duration) var(--nav-ease),
      box-shadow var(--nav-duration) var(--nav-ease);
  }

  .navbar.is-scrolled {
    background: #ffffff;
    box-shadow: 0 1px 0 rgba(74, 64, 58, 0.08);
  }

  .navbar__inner {
    width: 100%;
    padding: 1rem 1.25rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  @media (min-width: 900px) and (max-width: 1199px) {
    .navbar__inner { padding: 1rem 2rem; }
  }

  @media (min-width: 1200px) {
    .navbar__inner { padding: 1.5rem 3.5rem; }
  }

  .navbar__logo {
    justify-self: start;
    grid-column: 1;
    position: relative;
    display: inline-block;
    height: clamp(2rem, 4vw, 4.5rem);
    transition: opacity 0.3s linear;
  }

  @media (hover: hover) {
    .navbar__logo:hover { opacity: 0.7; }
  }

  .navbar__logo-white {
    display: block;
    height: 100%;
    width: auto;
    position: relative;
    transition: opacity var(--nav-duration) var(--nav-ease);
    opacity: 1;
  }

  .navbar__logo-dark {
    display: block;
    height: 100%;
    width: auto;
    position: absolute;
    top: 0;
    left: 0;
    transition: opacity var(--nav-duration) var(--nav-ease);
    opacity: 0;
  }

  .navbar.is-scrolled .navbar__logo-white { opacity: 0; }
  .navbar.is-scrolled .navbar__logo-dark  { opacity: 1; }

  .navbar__nav {
    display: none;
    align-items: center;
    justify-self: center;
    grid-column: 2;
    gap: 0;
  }

  .navbar__dot {
    color: rgba(255, 255, 255, 0.3);
    font-size: clamp(0.9rem, 1.1vw, 1.3rem);
    font-style: normal;
    padding: 0 clamp(0.1rem, 0.2vw, 0.25rem);
    user-select: none;
    transition: color var(--nav-duration) var(--nav-ease);
  }

  .navbar__link {
    font-family: var(--font-display);
    font-size: clamp(0.95rem, 1.1vw, 1.1rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.03em;
    color: #ffffff;
    text-decoration: none;
    padding: 0.4rem clamp(0.3rem, 0.6vw, 1rem);
    position: relative;
    transition: color var(--nav-duration) var(--nav-ease);
    white-space: nowrap;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: clamp(0.3rem, 0.6vw, 1rem);
    right: clamp(0.3rem, 0.6vw, 1rem);
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (hover: hover) {
    .navbar__link:hover::after { transform: scaleX(1); }
  }

  .navbar.is-scrolled .navbar__link { color: var(--color-brown); }
  .navbar.is-scrolled .navbar__dot  { color: rgba(74, 64, 58, 0.25); }

  .navbar__cta {
    display: none;
    justify-self: end;
    grid-column: 3;
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.03em;
    text-transform: none;
    text-decoration: none;
    color: #ffffff;
    background: var(--color-btn);
    padding: 0.6rem clamp(0.9rem, 1.4vw, 1.75rem);
    border-radius: 999px;
    white-space: nowrap;
    transition: background 0.3s linear;
  }

  @media (hover: hover) {
    .navbar__cta:hover { background: var(--color-btn-hover); }
    .navbar.is-scrolled .navbar__cta:hover { background: var(--color-brown); }
  }

  .navbar__hamburger {
    display: flex;
    justify-self: end;
    grid-column: 3;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 7px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .navbar__hamburger span {
    display: block;
    width: 28px;
    height: 1.5px;
    background: #ffffff;
    border-radius: 999px;
    transform-origin: center;
    transition:
      transform  0.2s linear,
      background var(--nav-duration) var(--nav-ease);
  }

  .navbar.is-scrolled .navbar__hamburger span { background: var(--color-brown); }

  @media (min-width: 900px) {
    .navbar__nav       { display: flex; }
    .navbar__cta       { display: inline-flex; align-items: center; }
    .navbar__hamburger { display: none !important; }
    .mobile-menu       { display: none !important; }
  }

  /* ─── MOBILE MENU ─────────────────────────────────────────── */

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 999;
    background: var(--color-brown);

    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;

    overflow-y: auto;
    -webkit-overflow-scrolling: touch;

    padding: clamp(1.5rem, 5vw, 2.5rem) 1.5rem clamp(2rem, 6vw, 3rem);

    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s linear, visibility 0.2s linear;
  }

  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-menu__link {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 4.5vw, 1.8rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.03em;
    color: #ffffff;
    text-decoration: none;
    text-align: center;
    position: relative;
    display: block;
    width: 100%;
    padding: 0.95rem 0;
  }

  .mobile-menu__link::after {
    content: '';
    position: absolute;
    bottom: 4px;
    left: 0;
    right: 0;
    height: 1px;
    background: #ffffff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-menu__cta {
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 4vw, 1.45rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.03em;
    text-decoration: none;
    color: #ffffff;
    background: var(--color-btn);
    padding: 0.85rem 2.25rem;
    border-radius: 999px;
    margin-top: 2.25rem;
    align-self: center;
    transition: background 0.3s linear;
  }

  @media (hover: hover) {
    .mobile-menu__link:hover::after { transform: scaleX(1); }
    .mobile-menu__cta:hover { background: var(--color-btn-hover); }
  }

  @media (prefers-reduced-motion: reduce) {
    .navbar,
    .navbar__logo,
    .navbar__logo-white,
    .navbar__logo-dark,
    .navbar__link,
    .navbar__link::after,
    .navbar__dot,
    .navbar__cta,
    .navbar__hamburger span,
    .mobile-menu,
    .mobile-menu__link::after,
    .mobile-menu__cta {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-delay: 0s !important;
    }
  }
</style>

<script>
  let isOpen = false;
  let trapHandler: ((e: KeyboardEvent) => void) | null = null;
  let resizeHandler: (() => void) | null = null;
  let scrollHandler: (() => void) | null = null;

  const SCROLL_THRESHOLD = 80;

  function initMenu() {
    const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu') as HTMLElement | null;
    const navbar = document.getElementById('navbar') as HTMLElement | null;
    const lines = toggle?.querySelectorAll('span');
    const links = menu?.querySelectorAll('a');

    if (!toggle || !menu || !navbar) return;

    const forceScrolled = navbar.dataset.forceScrolled === 'true';

    const updateScrollState = () => {
      if (forceScrolled || isOpen) {
        navbar.classList.add('is-scrolled');
        return;
      }
      window.scrollY > SCROLL_THRESHOLD
        ? navbar.classList.add('is-scrolled')
        : navbar.classList.remove('is-scrolled');
    };

    if (scrollHandler) window.removeEventListener('scroll', scrollHandler);
    scrollHandler = updateScrollState;
    window.addEventListener('scroll', scrollHandler, { passive: true });
    updateScrollState();

    if (trapHandler) { document.removeEventListener('keydown', trapHandler); trapHandler = null; }
    if (resizeHandler) { window.removeEventListener('resize', resizeHandler); resizeHandler = null; }

    isOpen = false;
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    menu.classList.remove('is-open');

    const setMenuTop = () => {
      menu.style.top = `${navbar.getBoundingClientRect().height}px`;
    };

    const openMenu = () => {
      setMenuTop();
      isOpen = true;
      toggle.setAttribute('aria-expanded', 'true');
      menu.setAttribute('aria-hidden', 'false');
      menu.classList.add('is-open');
      toggle.setAttribute('aria-label', 'Zavřít menu');
      navbar.classList.add('is-scrolled');
      document.body.style.overflow = 'hidden';
      const firstLink = menu.querySelector('a');
      if (firstLink) (firstLink as HTMLElement).focus();
      if (lines) {
        (lines[0] as HTMLElement).style.transform = 'translateY(4px) rotate(45deg)';
        (lines[1] as HTMLElement).style.transform = 'translateY(-4px) rotate(-45deg)';
      }
      trapHandler = (e: KeyboardEvent) => {
        if (e.key === 'Escape') { closeMenu(); toggle.focus(); }
      };
      document.addEventListener('keydown', trapHandler);
    };

    const closeMenu = () => {
      isOpen = false;
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      menu.classList.remove('is-open');
      toggle.setAttribute('aria-label', 'Otevřít menu');
      document.body.style.overflow = '';
      if (!forceScrolled && window.scrollY <= SCROLL_THRESHOLD) {
        navbar.classList.remove('is-scrolled');
      }
      if (lines) {
        (lines[0] as HTMLElement).style.transform = 'none';
        (lines[1] as HTMLElement).style.transform = 'none';
      }
      if (trapHandler) { document.removeEventListener('keydown', trapHandler); trapHandler = null; }
    };

    resizeHandler = () => {
      if (window.innerWidth >= 900 && isOpen) closeMenu();
      if (isOpen) setMenuTop();
    };
    window.addEventListener('resize', resizeHandler);

    toggle.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
    links?.forEach(link => link.addEventListener('click', () => { if (isOpen) closeMenu(); }));
  }

  document.addEventListener('astro:page-load', initMenu);
  initMenu();
</script>