---
// src/components/Navbar.astro
---

<header class="navbar" id="navbar" role="banner">
  <div class="navbar__inner">

    <a href="/" class="navbar__logo" aria-label="Zpět na hlavní stránku – Lagoon Masáže">
      <img class="navbar__logo-img navbar__logo-white" src="/logo.png" alt="" width="160" height="40" />
      <img class="navbar__logo-img navbar__logo-dark"  src="/lagoon-bronze.png" alt="" width="160" height="40" aria-hidden="true" />
    </a>

    <nav class="navbar__nav" aria-label="Hlavní navigace">
      <a href="#typy-masazi" class="navbar__link">Typy masáží</a>
      <span class="navbar__dot" aria-hidden="true">·</span>
      <a href="#jak-to-funguje" class="navbar__link">Jak to u nás funguje</a>
      <span class="navbar__dot" aria-hidden="true">·</span>
      <a href="#kontakt" class="navbar__link">Kontakt</a>
    </nav>

    <a href="#rezervace" class="navbar__cta">Rezervace</a>

    <button
      id="menu-toggle"
      class="navbar__hamburger"
      aria-label="Otevřít menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span>
      <span></span>
    </button>

  </div>
</header>

<nav id="mobile-menu" class="mobile-menu" aria-label="Mobilní navigace" aria-hidden="true">
  <a href="#typy-masazi" class="mobile-menu__link">Typy masáží</a>
  <a href="#jak-to-funguje" class="mobile-menu__link">Jak to u nás funguje</a>
  <a href="#kontakt" class="mobile-menu__link">Kontakt</a>
  <a href="#rezervace" class="mobile-menu__cta">Rezervace</a>
</nav>

<style>
  :root {
    --nav-duration: 0.6s;
    --nav-ease: linear;
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 50;
    background: transparent;
    box-shadow: none;
    transition:
      background var(--nav-duration) var(--nav-ease),
      box-shadow var(--nav-duration) var(--nav-ease);
  }

  .navbar.is-scrolled {
    background: #ffffff;
    box-shadow: 0 1px 0 rgba(74, 64, 58, 0.08);
  }

  .navbar__inner {
    width: 100%;
    padding: 1rem 1.25rem;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
  }

  @media (min-width: 900px) {
    .navbar__inner { padding: 1.5rem 3.5rem; }
  }

  /* ── Logo crossfade ── */
  .navbar__logo {
    justify-self: start;
    grid-column: 1;
    position: relative;
    display: inline-block;
    height: clamp(2.8rem, 6vw, 4.5rem);
    transition: opacity 0.3s linear;
  }

  @media (hover: hover) {
    .navbar__logo:hover { opacity: 0.7; }
  }

  .navbar__logo-white {
    display: block;
    height: 100%;
    width: auto;
    position: relative;
    transition: opacity var(--nav-duration) var(--nav-ease);
    opacity: 1;
  }

  .navbar__logo-dark {
    display: block;
    height: 100%;
    width: auto;
    position: absolute;
    top: 0;
    left: 0;
    transition: opacity var(--nav-duration) var(--nav-ease);
    opacity: 0;
  }

  .navbar.is-scrolled .navbar__logo-white { opacity: 0; }
  .navbar.is-scrolled .navbar__logo-dark  { opacity: 1; }

  /* ── Nav ── */
  .navbar__nav {
    display: none;
    align-items: center;
    justify-self: center;
    grid-column: 2;
    gap: 0;
  }

  .navbar__dot {
    color: rgba(255, 255, 255, 0.3);
    font-size: 1.3rem;
    font-style: normal;
    padding: 0 0.25rem;
    user-select: none;
    transition: color var(--nav-duration) var(--nav-ease);
  }

  .navbar__link {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.04em;
    color: #ffffff;
    text-decoration: none;
    padding: 0.4rem 1rem;
    position: relative;
    transition: color var(--nav-duration) var(--nav-ease);
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  @media (hover: hover) {
    .navbar__link:hover::after { transform: scaleX(1); }
  }

  .navbar.is-scrolled .navbar__link { color: var(--color-brown); }
  .navbar.is-scrolled .navbar__dot  { color: rgba(74, 64, 58, 0.25); }

  /* ── CTA ── */
  .navbar__cta {
    display: none;
    justify-self: end;
    grid-column: 3;
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--color-brown);
    background: var(--color-gold);
    padding: 0.6rem 2rem;
    border-radius: 999px;
    transition: background 0.3s linear, color 0.3s linear;
  }

  @media (hover: hover) {
    .navbar__cta:hover { background: #ffffff; color: var(--color-brown); }
    .navbar.is-scrolled .navbar__cta:hover { background: var(--color-brown); color: #ffffff; }
  }

  /* ── Hamburger ── */
  .navbar__hamburger {
    display: flex;
    justify-self: end;
    grid-column: 3;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 7px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .navbar__hamburger span {
    display: block;
    width: 28px;
    height: 1.5px;
    background: #ffffff;
    border-radius: 999px;
    transform-origin: center;
    transition:
      transform  0.2s linear,
      background var(--nav-duration) var(--nav-ease);
  }

  .navbar.is-scrolled .navbar__hamburger span { background: var(--color-brown); }

  @media (min-width: 900px) {
    .navbar__nav       { display: flex; }
    .navbar__cta       { display: inline-flex; align-items: center; }
    .navbar__hamburger { display: none !important; }
    .mobile-menu       { display: none !important; }
  }

  /* ── Mobile menu ── */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 40;
    background: var(--color-brown);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2.75rem;
    
    /* A11y: Zajišťuje bezpečné skrytí před tabulátorem, dokud se neotevře */
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.2s linear, visibility 0.2s linear;
  }

  .mobile-menu.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .mobile-menu__link {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.04em;
    color: #ffffff;
    text-decoration: none;
    text-align: center;
    position: relative;
  }

  .mobile-menu__link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 1px;
    background: #ffffff;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .mobile-menu__cta {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 5vw, 2rem);
    font-weight: 300;
    font-style: italic;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--color-brown);
    background: var(--color-gold);
    padding: 0.75rem 2.75rem;
    border-radius: 999px;
    margin-top: 0.5rem;
    transition: background 0.3s linear, color 0.3s linear;
  }

  @media (hover: hover) {
    .mobile-menu__link:hover::after { transform: scaleX(1); }
    .mobile-menu__cta:hover { background: #ffffff; color: var(--color-brown); }
  }

  /* ── REDUCED MOTION ACCEPTANCE ── */
  /* Vypíná nebo zpomaluje animace pro uživatele, kteří mají v systému nastaveno omezení pohybu */
  @media (prefers-reduced-motion: reduce) {
    .navbar,
    .navbar__logo,
    .navbar__logo-white,
    .navbar__logo-dark,
    .navbar__link,
    .navbar__link::after,
    .navbar__dot,
    .navbar__cta,
    .navbar__hamburger span,
    .mobile-menu,
    .mobile-menu__link::after,
    .mobile-menu__cta {
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-delay: 0s !important;
    }
  }
</style>

<script>
  let isOpen = false;
  let trapHandler: ((e: KeyboardEvent) => void) | null = null;
  let resizeHandler: (() => void) | null = null;
  let scrollHandler: (() => void) | null = null;

  const SCROLL_THRESHOLD = 80;

  function initMenu() {
    const toggle = document.getElementById('menu-toggle') as HTMLButtonElement | null;
    const menu = document.getElementById('mobile-menu');
    const navbar = document.getElementById('navbar');
    const lines = toggle?.querySelectorAll('span');
    const links = menu?.querySelectorAll('a');

    if (!toggle || !menu || !navbar) return;

    const updateScrollState = () => {
      window.scrollY > SCROLL_THRESHOLD
        ? navbar.classList.add('is-scrolled')
        : navbar.classList.remove('is-scrolled');
    };

    if (scrollHandler) window.removeEventListener('scroll', scrollHandler);
    scrollHandler = updateScrollState;
    window.addEventListener('scroll', scrollHandler, { passive: true });
    updateScrollState();

    if (trapHandler) { document.removeEventListener('keydown', trapHandler); trapHandler = null; }
    if (resizeHandler) { window.removeEventListener('resize', resizeHandler); resizeHandler = null; }

    isOpen = false;
    
    // A11y reset do zavřeného stavu
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    menu.classList.remove('is-open');

    const openMenu = () => {
      isOpen = true;
      
      // A11y aktualizace stavů pro čtečky
      toggle.setAttribute('aria-expanded', 'true');
      menu.setAttribute('aria-hidden', 'false');
      
      menu.classList.add('is-open');
      if (lines) {
        (lines[0] as HTMLElement).style.transform = 'translateY(4px) rotate(45deg)';
        (lines[1] as HTMLElement).style.transform = 'translateY(-4px) rotate(-45deg)';
      }
      
      // Focus Trap pro únik z menu pomocí klávesy ESC
      trapHandler = (e: KeyboardEvent) => {
        if (e.key === 'Escape') { closeMenu(); toggle.focus(); }
      };
      document.addEventListener('keydown', trapHandler);
    };

    const closeMenu = () => {
      isOpen = false;
      
      // A11y znovuzamčení menu
      toggle.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      
      menu.classList.remove('is-open');
      if (lines) {
        (lines[0] as HTMLElement).style.transform = 'none';
        (lines[1] as HTMLElement).style.transform = 'none';
      }
      if (trapHandler) { document.removeEventListener('keydown', trapHandler); trapHandler = null; }
    };

    resizeHandler = () => {
      if (window.innerWidth >= 900 && isOpen) closeMenu();
    };
    window.addEventListener('resize', resizeHandler);

    toggle.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
    
    // Automatické zavření mobilního menu po kliknutí na nějaký odkaz (A11y friendly)
    links?.forEach(link => link.addEventListener('click', () => { if (isOpen) closeMenu(); }));
  }

  document.addEventListener('astro:page-load', initMenu);
  initMenu();
</script>