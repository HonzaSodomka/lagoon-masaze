---
// src/components/Masaze.astro
import { Flame, Waves, Sparkles, Zap, Heart, Footprints, Activity, Smile, Gift, ChevronDown } from 'lucide-astro';
---

<section id="typy-masazi" class="masaze" aria-labelledby="masaze-heading">
  <div class="masaze__container">

    <div class="masaze__header scroll-animate">
      <span class="masaze__eyebrow">Naše nabídka</span>
      <h2 id="masaze-heading" class="masaze__title">Typy masáží</h2>
      <p class="masaze__subtitle">Osm druhů orientálních procedur — každá jiná, každá výjimečná.</p>
    </div>

    <div class="masaze__grid" id="masazeGrid" role="group" aria-label="Seznam nabízených masáží">

      <article class="masaze__card scroll-animate" data-id="0">
        <div class="masaze__card-image">
          <img src="/masaz-pro-dva.webp" alt="Žena relaxuje při párové masáži při svíčkách v masážní místnosti" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Heart size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Masáž pro dva</h3>
            <p class="masaze__card-short">Společný zážitek ve stejný čas, každý dle svých preferencí.</p>
          </div>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>Cena dle výběru masáže</span>
          </div>
          <a href="/rezervace" class="masaze__card-cta" aria-label="Rezervovat Masáž pro dva">Rezervovat</a>
        </div>
        <button class="masaze__toggle" aria-expanded="false" aria-controls="masaze-detail-0">
          <span>Detail masáže</span>
          <ChevronDown size={16} class="masaze__chevron" aria-hidden="true" />
        </button>
      </article>

      <article class="masaze__card scroll-animate" data-id="1">
        <div class="masaze__card-image">
          <img src="/masaz-thajska.webp" alt="Masérka provádí thajskou olejovou masáž šíje a ramen ležící ženy" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Flame size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Thajská olejová masáž</h3>
            <p class="masaze__card-short">Uvolnění ztuhlého těla a regenerace svalů.</p>
          </div>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>60 min — <strong>800 Kč</strong></span>
            <span>90 min — <strong>1 200 Kč</strong></span>
          </div>
          <a href="/rezervace" class="masaze__card-cta" aria-label="Rezervovat Thajskou olejovou masáž">Rezervovat</a>
        </div>
        <button class="masaze__toggle" aria-expanded="false" aria-controls="masaze-detail-1">
          <span>Detail masáže</span>
          <ChevronDown size={16} class="masaze__chevron" aria-hidden="true" />
        </button>
      </article>

      <article class="masaze__card scroll-animate" data-id="2">
        <div class="masaze__card-image">
          <img src="/masaz-filipinska.webp" alt="Masérka provádí filipínskou olejovou masáž relaxující ženy" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Waves size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Filipínská olejová masáž</h3>
            <p class="masaze__card-short">Příjemná relaxace a odpočinek od každodenního stresu.</p>
          </div>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>60 min — <strong>800 Kč</strong></span>
            <span>90 min — <strong>1 200 Kč</strong></span>
          </div>
          <a href="/rezervace" class="masaze__card-cta" aria-label="Rezervovat Filipínskou olejovou masáž">Rezervovat</a>
        </div>
        <button class="masaze__toggle" aria-expanded="false" aria-controls="masaze-detail-2">
          <span>Detail masáže</span>
          <ChevronDown size={16} class="masaze__chevron" aria-hidden="true" />
        </button>
      </article>

      <article class="masaze__card scroll-animate" data-id="3">
        <div class="masaze__card-image">
          <img src="/masaz-ajurvedska.webp" alt="Žena relaxuje při ajurvédské masáži" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Sparkles size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Ajurvédská masáž</h3>
            <p class="masaze__card-short">Harmonizace těla a mysli pomocí teplých olejů.</p>
          </div>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>60 min — <strong>800 Kč</strong></span>
            <span>90 min — <strong>1 200 Kč</strong></span>
          </div>
          <a href="/rezervace" class="masaze__card-cta" aria-label="Rezervovat Ajurvédskou masáž">Rezervovat</a>
        </div>
        <button class="masaze__toggle" aria-expanded="false" aria-controls="masaze-detail-3">
          <span>Detail masáže</span>
          <ChevronDown size={16} class="masaze__chevron" aria-hidden="true" />
        </button>
      </article>

      <article class="masaze__card scroll-animate" data-id="4">
        <div class="masaze__card-image">
          <img src="/masaz-shiatsu-abhyanga.webp" alt="Masérka provádí hlubokou masáž zad s olejem technikou Shiatsu Abhyanga" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Zap size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Shiatsu + Abhyanga</h3>
            <p class="masaze__card-short">Spojení tlakových technik a hluboké relaxace.</p>
          </div>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>60 min — <strong>800 Kč</strong></span>
            <span>90 min — <strong>1 200 Kč</strong></span>
          </div>
          <a href="/rezervace" class="masaze__card-cta" aria-label="Rezervovat Shiatsu s Abhyangou">Rezervovat</a>
        </div>
        <button class="masaze__toggle" aria-expanded="false" aria-controls="masaze-detail-4">
          <span>Detail masáže</span>
          <ChevronDown size={16} class="masaze__chevron" aria-hidden="true" />
        </button>
      </article>

      <article class="masaze__card scroll-animate" data-id="5">
        <div class="masaze__card-image">
          <img src="/masaz-reflexni-nohy.webp" alt="Masérka provádí reflexní masáž chodidel a nohou klientky" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Footprints size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Reflexní masáž nohou</h3>
            <p class="masaze__card-short">Úleva pro unavené nohy a navození pocitu lehkosti.</p>
          </div>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>30 min — <strong>500 Kč</strong></span>
          </div>
          <a href="/rezervace" class="masaze__card-cta" aria-label="Rezervovat Reflexní masáž nohou">Rezervovat</a>
        </div>
        <button class="masaze__toggle" aria-expanded="false" aria-controls="masaze-detail-5">
          <span>Detail masáže</span>
          <ChevronDown size={16} class="masaze__chevron" aria-hidden="true" />
        </button>
      </article>

      <article class="masaze__card scroll-animate" data-id="6">
        <div class="masaze__card-image">
          <img src="/masaz-zada-sije.webp" alt="Masérka provádí masáž zad a ramen ležící ženy" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Activity size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Masáž zad a šíje</h3>
            <p class="masaze__card-short">Rychlá pomoc pro záda, krk a ramena.</p>
          </div>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>30 min — <strong>500 Kč</strong></span>
          </div>
          <a href="/rezervace" class="masaze__card-cta" aria-label="Rezervovat Masáž zad a šíje">Rezervovat</a>
        </div>
        <button class="masaze__toggle" aria-expanded="false" aria-controls="masaze-detail-6">
          <span>Detail masáže</span>
          <ChevronDown size={16} class="masaze__chevron" aria-hidden="true" />
        </button>
      </article>

      <article class="masaze__card scroll-animate" data-id="7">
        <div class="masaze__card-image">
          <img src="/masaz-hlava-oblicej.webp" alt="Žena relaxuje při masáži hlavy a obličeje se zavřenýma očima" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Smile size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Masáž hlavy a obličeje</h3>
            <p class="masaze__card-short">Uvolnění napětí a příjemná relaxace.</p>
          </div>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>30 min — <strong>500 Kč</strong></span>
          </div>
          <a href="/rezervace" class="masaze__card-cta" aria-label="Rezervovat Masáž hlavy a obličeje">Rezervovat</a>
        </div>
        <button class="masaze__toggle" aria-expanded="false" aria-controls="masaze-detail-7">
          <span>Detail masáže</span>
          <ChevronDown size={16} class="masaze__chevron" aria-hidden="true" />
        </button>
      </article>

      <article class="masaze__card masaze__card--voucher scroll-animate" id="darkovy-poukaz" data-id="voucher">
        <div class="masaze__card-image">
          <img src="/darkovy-poukaz.webp" alt="Dárkový poukaz Lagoon Masáže" width="600" height="600" loading="lazy" decoding="async" />
        </div>
        <div class="masaze__card-top">
          <div class="masaze__card-icon" aria-hidden="true"><Gift size={22} /></div>
          <div>
            <h3 class="masaze__card-title">Dárkový poukaz</h3>
            <p class="masaze__card-short">Dostupné přímo v salonu nebo z automatu před vchodem.</p>
          </div>
        </div>
        <div class="masaze__card-desc">
          <p>Poukaz lze zakoupit na 30, 60 nebo 90 minut a nemá datum expirace. Držitel si vybere masáž dle délky na poukazu.</p>
          <p>Osobně v salonu Po–So 8–20 h (zavolejte 10 min předem), nebo z automatu před vchodem kdykoliv — jen mějte hotovost a přesnou částku.</p>
        </div>
        <div class="masaze__card-footer">
          <div class="masaze__prices">
            <span>30 / 60 / 90 minut</span>
          </div>
          <a href="tel:+420732596212" class="masaze__card-cta" aria-label="Zavolat ohledně dárkového poukazu">Zavolat</a>
        </div>
      </article>

    </div>

    <div id="masaze-detail-0" class="masaze-detail" role="region" aria-label="Detail: Masáž pro dva" aria-hidden="true">
      <div class="masaze-detail__inner">
        <p>Dopřejte si společný čas plný odpočinku a relaxace. Masáže probíhají současně v oddělených místnostech, přičemž každý klient si může vybrat masáž podle svých preferencí. Ideální volba pro všechny, kteří si chtějí dopřát společný zážitek a následně sdílet příjemný pocit odpočinku a regenerace.</p>
      </div>
    </div>

    <div id="masaze-detail-1" class="masaze-detail" role="region" aria-label="Detail: Thajská olejová masáž" aria-hidden="true">
      <div class="masaze-detail__inner">
        <p>Tradiční masáž kombinující práci s tlakovými body, jemné protahování a masážní olej. Pomáhá uvolnit ztuhlé svaly, zmírnit napětí v těle a podpořit celkovou regeneraci. Oproti klasické thajské masáži je díky použití oleje příjemnější a vhodná i pro klienty, kteří s thajskými masážemi teprve začínají.</p>
        <p class="masaze-detail__vhodna"><strong>Vhodná pro:</strong> ztuhlé svaly, napětí v těle, regeneraci a obnovení flexibility.</p>
      </div>
    </div>

    <div id="masaze-detail-2" class="masaze-detail" role="region" aria-label="Detail: Filipínská olejová masáž" aria-hidden="true">
      <div class="masaze-detail__inner">
        <p>Relaxační masáž využívající plynulé a rytmické tahy s použitím masážního oleje. Zaměřuje se na uvolnění svalového napětí, podporu krevního oběhu a celkové zklidnění organismu. Oproti thajské olejové masáži je zaměřena především na plynulé masážní techniky a hlubokou relaxaci bez prvků protahování.</p>
        <p class="masaze-detail__vhodna"><strong>Vhodná pro:</strong> relaxaci, stres, únavu a celkové zklidnění.</p>
      </div>
    </div>

    <div id="masaze-detail-3" class="masaze-detail" role="region" aria-label="Detail: Ajurvédská masáž" aria-hidden="true">
      <div class="masaze-detail__inner">
        <p>Tradiční indická masáž využívající teplé oleje a dlouhé harmonizační tahy. Jejím cílem je navodit hluboký pocit klidu, podpořit regeneraci organismu a přispět k celkové harmonii těla a mysli. Patří mezi nejjemnější masáže v naší nabídce a je zaměřena především na odpočinek a relaxaci.</p>
        <p class="masaze-detail__vhodna"><strong>Vhodná pro:</strong> hlubokou relaxaci, odpočinek, zklidnění mysli a načerpání nové energie.</p>
      </div>
    </div>

    <div id="masaze-detail-4" class="masaze-detail" role="region" aria-label="Detail: Shiatsu + Abhyanga" aria-hidden="true">
      <div class="masaze-detail__inner">
        <p>Jedinečné spojení japonské tlakové masáže Shiatsu a tradiční ajurvédské techniky Abhyanga. Kombinuje práci s tlakovými body, energetickými drahami a relaxační účinky teplého oleje. Pomáhá obnovit rovnováhu organismu, uvolnit nahromaděné napětí a podpořit celkovou regeneraci.</p>
        <p class="masaze-detail__vhodna"><strong>Vhodná pro:</strong> stres, napětí v těle, regeneraci a harmonizaci organismu.</p>
      </div>
    </div>

    <div id="masaze-detail-5" class="masaze-detail" role="region" aria-label="Detail: Reflexní masáž nohou" aria-hidden="true">
      <div class="masaze-detail__inner">
        <p>Masáž zaměřená na chodidla, kotníky a lýtka. Pomocí stimulace reflexních bodů pomáhá uvolnit unavené nohy, podpořit krevní oběh a navodit pocit lehkosti. Je příjemnou volbou zejména po dlouhém dni na nohou nebo při pocitu únavy dolních končetin.</p>
        <p class="masaze-detail__vhodna"><strong>Vhodná pro:</strong> unavené nohy, pocit těžkých nohou, uvolnění a regeneraci.</p>
      </div>
    </div>

    <div id="masaze-detail-6" class="masaze-detail" role="region" aria-label="Detail: Masáž zad a šíje" aria-hidden="true">
      <div class="masaze-detail__inner">
        <p>Cílená masáž zaměřená na oblast zad, ramen a krku, kde se nejčastěji hromadí napětí způsobené stresem, fyzickou zátěží nebo dlouhodobým setrváním v jedné poloze. Pomáhá uvolnit ztuhlé svaly, zmírnit nepříjemné napětí a přinést úlevu od každodenní zátěže.</p>
        <p class="masaze-detail__vhodna"><strong>Vhodná pro:</strong> ztuhlá záda, napětí v oblasti krku a ramen, svalovou únavu a regeneraci.</p>
      </div>
    </div>

    <div id="masaze-detail-7" class="masaze-detail" role="region" aria-label="Detail: Masáž hlavy a obličeje" aria-hidden="true">
      <div class="masaze-detail__inner">
        <p>Jemná relaxační masáž zaměřená na oblast hlavy, obličeje a spánků. Pomáhá uvolnit napětí, podpořit prokrvení pokožky a navodit hluboký pocit klidu. Pravidelná masáž může přispět ke svěžejšímu a odpočatějšímu vzhledu pleti a podpořit její přirozenou regeneraci.</p>
        <p class="masaze-detail__vhodna"><strong>Vhodná pro:</strong> stres, napětí v oblasti hlavy, relaxaci a svěží vzhled.</p>
      </div>
    </div>

  </div>

  <div class="masaze__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#4A403A"/>
    </svg>
  </div>
</section>

<style>
  .masaze {
    --card-bg:     #fff;
    --card-border: rgba(74, 64, 58, 0.09);
    --card-radius: 0.875rem;
    --brown:       #4a403a;
    --brown-06:    rgba(74, 64, 58, 0.6);
    --brown-045:   rgba(74, 64, 58, 0.45);
    --anim:        0.42s cubic-bezier(0.16, 1, 0.3, 1);

    background: #f5f0ea;
    padding: clamp(4rem, 8vw, 8rem) 0;
    position: relative;
  }

  .masaze__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    z-index: 1;
    line-height: 0;
  }

  .masaze__wave svg {
    display: block;
    width: 100%;
    height: clamp(35px, 5vw, 70px);
  }

  .masaze__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3.5rem);
  }

  .masaze__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  @media (min-width: 900px) {
    .masaze__header   { align-items: center; text-align: center; }
    .masaze__subtitle { margin-inline: auto; }
  }
  .masaze__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }
  .masaze__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.25rem);
    font-weight: 300;
    font-style: normal;
    line-height: 1.05;
    color: var(--color-brown);
    margin: 0 0 1rem;
  }
  .masaze__subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--brown-06);
    max-width: 480px;
    line-height: 1.6;
    margin: 0;
  }

  .masaze__grid {
    display: grid;
    grid-template-columns: 1fr;
    column-gap: 1rem;
    margin-top: -0.5rem;
  }
  @media (min-width: 640px)  { .masaze__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .masaze__grid { grid-template-columns: repeat(3, 1fr); } }

  .masaze__card {
    display: flex;
    flex-direction: column;
    background: var(--card-bg);
    border-radius: var(--card-radius);
    overflow: hidden;
    box-shadow: 0 1px 4px rgba(74, 64, 58, 0.07);
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    transition: box-shadow 0.3s ease, transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s linear;
  }
  .masaze__card.is-active { box-shadow: 0 4px 20px rgba(74, 64, 58, 0.13); }
  @media (hover: hover) {
    .masaze__card:hover { box-shadow: 0 4px 20px rgba(74, 64, 58, 0.11); }
  }

  .masaze__card-image {
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: #e8e2da;
    flex-shrink: 0;
  }
  .masaze__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @media (hover: hover) {
    .masaze__card:hover .masaze__card-image img {
      transform: scale(1.04);
    }
  }

  .masaze__card-top {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    padding: 1.25rem 1.5rem 0.75rem;
    flex: 1;
  }
  .masaze__card-icon {
    width: 1.4rem;
    height: 1.4rem;
    color: var(--color-gold);
    flex-shrink: 0;
    margin-top: 0.15rem;
  }
  .masaze__card-icon svg { width: 100%; height: 100%; stroke-width: 1.5; stroke: currentColor; fill: none; }

  .masaze__card-title {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.5vw, 1.35rem);
    font-weight: 400;
    font-style: normal;
    line-height: 1.2;
    color: var(--color-brown);
    margin: 0 0 0.3rem;
  }
  .masaze__card-short {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--brown-06);
    line-height: 1.5;
    margin: 0;
  }

  .masaze__card-desc {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0 1.5rem 1rem;
  }
  .masaze__card-desc p {
    font-family: var(--font-body);
    font-size: 0.875rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
  }

  .masaze__card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    border-top: 1px solid var(--card-border);
    margin-top: auto;
  }
  .masaze__prices         { display: flex; flex-direction: column; gap: 0.15rem; }
  .masaze__prices span    { font-family: var(--font-body); font-size: 0.875rem; color: var(--brown-06); }
  .masaze__prices strong  { font-weight: 600; color: var(--brown); }

  .masaze__card-cta {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: normal;
    text-decoration: none;
    color: #fff;
    background: var(--color-btn);
    border: 1px solid var(--color-btn);
    padding: 0.45rem 1.1rem;
    border-radius: 999px;
    white-space: nowrap;
    transition: background 0.25s, border-color 0.25s;
  }

  @media (hover: hover) {
    .masaze__card-cta:hover { background: var(--color-btn-hover); border-color: var(--color-btn-hover); }
    .masaze__card--voucher .masaze__card-cta:hover { background: var(--color-btn-hover); border-color: var(--color-btn-hover); }
  }

  .masaze__toggle {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    background: none;
    border: none;
    border-top: 1px solid rgba(74, 64, 58, 0.07);
    padding: 0.65rem 1.5rem;
    color: var(--brown-045);
    cursor: pointer;
    transition: color 0.2s;
  }
  .masaze__toggle span {
    font-family: var(--font-body);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.13em;
  }
  .masaze__chevron { width: 1rem; height: 1rem; flex-shrink: 0; transition: transform var(--anim); }
  .masaze__chevron svg { width: 100%; height: 100%; stroke-width: 2; }
  .masaze__toggle[aria-expanded="true"] .masaze__chevron { transform: rotate(180deg); }

  .masaze__card.is-active .masaze__toggle,
  .masaze__card--voucher.is-active .masaze__toggle { color: var(--color-gold); }

  @media (hover: hover) {
    .masaze__toggle:hover { color: var(--color-gold); }
    .masaze__card--voucher .masaze__toggle:hover { color: var(--color-gold); }
  }

  .masaze__card--voucher                        { background: var(--color-brown); }
  .masaze__card--voucher .masaze__card-image    { background: rgba(0, 0, 0, 0.2); }
  .masaze__card--voucher .masaze__card-icon     { color: var(--color-gold); }
  .masaze__card--voucher .masaze__card-title    { color: #fff; }
  .masaze__card--voucher .masaze__card-short    { color: rgba(255, 255, 255, 0.6); }
  .masaze__card--voucher .masaze__card-footer   { border-top-color: rgba(255, 255, 255, 0.1); }
  .masaze__card--voucher .masaze__prices span   { color: rgba(255, 255, 255, 0.55); }
  .masaze__card--voucher .masaze__prices strong { color: #fff; }
  .masaze__card--voucher .masaze__card-cta      { color: var(--color-gold); background: transparent; border-color: rgba(198, 162, 122, 0.45); }
  @media (hover: hover) {
    .masaze__card--voucher .masaze__card-cta:hover { background: var(--color-btn); border-color: var(--color-btn); color: #fff; }
  }
  .masaze__card--voucher .masaze__toggle        { border-top-color: rgba(255, 255, 255, 0.08); color: rgba(255, 255, 255, 0.4); }

  .masaze-detail {
    display: none;
    grid-column: 1 / -1;
    background: var(--card-bg);
    border-radius: var(--card-radius);
    position: relative;
  }

  .masaze-detail::before {
    content: '';
    position: absolute;
    top: -7px;
    left: var(--arrow-pos, 50%);
    transform: translateX(-50%) rotate(45deg);
    width: 14px;
    height: 14px;
    background: var(--card-bg);
    border-top: 1px solid var(--card-border);
    border-left: 1px solid var(--card-border);
    z-index: 10;
    opacity: 0;
    transition: opacity var(--anim);
    pointer-events: none;
  }
  .masaze-detail.is-open::before {
    opacity: 1;
  }

  .masaze-detail--ready {
    display: grid;
    grid-template-rows: 0fr;
    box-shadow: inset 0 0 0 1px rgba(74, 64, 58, 0);
    margin-top: 0;
    margin-bottom: 0;
    pointer-events: none;
    transition:
      grid-template-rows var(--anim),
      box-shadow         var(--anim),
      margin-top         var(--anim),
      margin-bottom      var(--anim);
  }
  .masaze-detail--ready.is-open {
    grid-template-rows: 1fr;
    box-shadow: inset 0 0 0 1px var(--card-border);
    margin-top: 0.5rem;
    margin-bottom: 0.5rem;
    pointer-events: auto;
  }

  .masaze-detail__inner {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0 clamp(1rem, 3vw, 2rem);
    transition: padding var(--anim);
  }
  .masaze-detail.is-open .masaze-detail__inner {
    padding: clamp(1.25rem, 3vw, 1.75rem) clamp(1rem, 3vw, 2rem);
  }

  .masaze-detail__inner p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.75;
    color: rgba(74, 64, 58, 0.75);
    margin: 0;
  }
  .masaze-detail__vhodna        { font-size: 0.875rem; color: var(--brown-06); }
  .masaze-detail__vhodna strong { font-weight: 600; color: var(--brown); }

  .masaze-detail--dark { background: var(--color-brown); }
  .masaze-detail--dark.masaze-detail--ready.is-open { box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.07); }
  .masaze-detail--dark .masaze-detail__inner p      { color: rgba(255, 255, 255, 0.82); }
  .masaze-detail--dark .masaze-detail__vhodna        { color: rgba(255, 255, 255, 0.6); }
  .masaze-detail--dark .masaze-detail__vhodna strong { color: rgba(255, 255, 255, 0.85); }

  .masaze-detail--dark::before {
    background: var(--color-brown);
    border-top-color: rgba(255, 255, 255, 0.07);
    border-left-color: rgba(255, 255, 255, 0.07);
  }

  .scroll-animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .masaze__card,
    .masaze__card-image img,
    .masaze-detail--ready,
    .masaze-detail__inner,
    .masaze__chevron,
    .masaze-detail::before,
    .scroll-animate {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>

<script is:inline>
(function () {
  document.addEventListener('DOMContentLoaded', function () {
    var ANIM_MS = 420;

    var grid = document.getElementById('masazeGrid');
    if (!grid) return;

    var container = grid.closest('.masaze__container');
    var cards     = Array.from(grid.querySelectorAll('.masaze__card[data-id]'));

    var details = {};
    grid.closest('.masaze__container').querySelectorAll('.masaze-detail[id]').forEach(function (el) {
      var key = el.id.replace('masaze-detail-', '');
      details[isNaN(key) ? key : parseInt(key)] = el;
    });

    var openId      = null;
    var isAnimating = false;

    function updateArrow(detail, card) {
      if (!detail || !card) return;
      var cardRect = card.getBoundingClientRect();
      var gridRect = grid.getBoundingClientRect();
      var centerPos = (cardRect.left - gridRect.left) + (cardRect.width / 2);
      detail.style.setProperty('--arrow-pos', centerPos + 'px');
    }

    function getCols() {
      var w = window.innerWidth;
      return w >= 1024 ? 3 : w >= 640 ? 2 : 1;
    }

    function getAnchor(cardIndex) {
      var row = Math.floor(cardIndex / getCols());
      var anchor = cards[cardIndex];
      cards.forEach(function (c, ci) {
        if (Math.floor(ci / getCols()) === row) anchor = c;
      });
      return anchor;
    }

    function insertDetail(detail, anchor) {
      anchor.parentNode.insertBefore(detail, anchor.nextSibling);
      detail.classList.add('masaze-detail--ready');
      detail.setAttribute('aria-hidden', 'false');
    }

    function detachDetail(detail) {
      detail.classList.remove('masaze-detail--ready', 'is-open');
      detail.setAttribute('aria-hidden', 'true');
      container.appendChild(detail);
    }

    function closeActive(cb) {
      if (openId === null) { cb && cb(); return; }

      var id     = openId;
      var detail = details[id];
      var card   = grid.querySelector('.masaze__card[data-id="' + id + '"]');

      openId = null;

      if (card) {
        card.classList.remove('is-active');
        var btn = card.querySelector('.masaze__toggle');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      }

      if (!detail) { cb && cb(); return; }

      detail.classList.remove('is-open');
      setTimeout(function () { detachDetail(detail); cb && cb(); }, ANIM_MS + 20);
    }

    function openDetail(id, card, cardIndex) {
      var detail = details[id];
      if (!detail) return;

      insertDetail(detail, getAnchor(cardIndex));
      updateArrow(detail, card);

      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          detail.classList.add('is-open');
          card.classList.add('is-active');
          var btn = card.querySelector('.masaze__toggle');
          if (btn) btn.setAttribute('aria-expanded', 'true');
          openId      = id;
          isAnimating = false;
        });
      });
    }

    cards.forEach(function (card, cardIndex) {
      var btn   = card.querySelector('.masaze__toggle');
      if (!btn) return;

      var rawId = card.dataset.id;
      var id    = rawId === 'voucher' ? 'voucher' : parseInt(rawId);
      if (rawId !== 'voucher' && isNaN(id)) return;

      // Rezervovat tlačítko nepropaguje klik na kartu
      var cta = card.querySelector('.masaze__card-cta');
      if (cta) {
        cta.addEventListener('click', function (e) { e.stopPropagation(); });
      }

      function toggleDetail() {
        if (isAnimating) return;

        if (openId === id) {
          isAnimating = true;
          closeActive(function () { isAnimating = false; });
          return;
        }

        isAnimating = true;

        if (openId === null) {
          openDetail(id, card, cardIndex);
        } else {
          closeActive(function () { openDetail(id, card, cardIndex); });
        }
      }

      btn.addEventListener('click', function(e) { e.stopPropagation(); toggleDetail(); });
      card.addEventListener('click', toggleDetail);
    });

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        if (openId === null) return;
        var activeIndex = cards.findIndex(function (c) { return c.dataset.id === String(openId); });
        if (activeIndex === -1) return;

        var anchor = getAnchor(activeIndex);
        var detail = details[openId];
        var activeCard = cards[activeIndex];

        if (detail && detail.previousSibling !== anchor) {
          anchor.parentNode.insertBefore(detail, anchor.nextSibling);
        }

        if (detail && activeCard) {
          updateArrow(detail, activeCard);
        }
      }, 150);
    });
  });
})();
</script>