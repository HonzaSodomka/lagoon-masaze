---
// src/components/Hero.astro
---

<section id="hero" class="hero" aria-labelledby="hero-heading">

  <video class="hero__bg" id="heroBg" autoplay muted loop playsinline aria-hidden="true">
    <source data-src="/lagoon.webm" type="video/webm" />
    <source data-src="/lagoon.mp4" type="video/mp4" />
  </video>

  <div class="hero__overlay" aria-hidden="true"></div>

  <div class="hero__container">
    <div class="hero__content">

      <h1 id="hero-heading" class="hero__h1">Masáže Mladá Boleslav</h1>

      <p class="hero__display">
        Tradiční masáže<br aria-hidden="true"/>v srdci města
      </p>

      <p class="hero__text">
        Orientální techniky, přírodní oleje<br class="hero__text-br"/> a tiché prostředí pro vaši relaxaci.
      </p>

      <div class="hero__actions">
        <a href="/rezervace" class="hero__btn-primary">Rezervovat masáž</a>
        <a href="https://maps.app.goo.gl/pAcxyPUEK9RcHGYa9"
          target="_blank"
          rel="noopener noreferrer"
          class="hero__reviews"
          aria-label="Hodnocení 4,9 hvězdy od více než 280 zákazníků na Google Maps"
        >
          <span class="hero__reviews-stars" aria-hidden="true">★★★★★</span>
          <span class="hero__reviews-divider" aria-hidden="true"></span>
          <span class="hero__reviews-text"><strong>4,9</strong> · 280+ recenzí</span>
        </a>
      </div>

    </div>
  </div>

  <div class="hero__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 90" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,55 C320,15 820,75 1440,35 L1440,90 L0,90 Z" fill="#f5f0ea" opacity="0.4"/>
      <path d="M0,70 C280,30 900,80 1440,50 L1440,90 L0,90 Z" fill="#f5f0ea"/>
    </svg>
  </div>

</section>

<style>
  .hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    min-height: 100vh;
    min-height: 100dvh;
  }

  @media (min-width: 900px) {
    .hero {
      align-items: center;
      justify-content: center;
    }
  }

  /* ── Video bg ── */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background-color: var(--color-brown, #4a403a);
    opacity: 0;
    transition: opacity 1s ease;
  }

  .hero__bg.is-loaded { opacity: 1; }

  /* ── Overlay ── */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.42);
    z-index: 1;
  }

  /* ── Container ── */
  .hero__container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin-inline: auto;
    padding: 0 1.25rem;
    padding-top: clamp(5rem, 12vw, 8rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
  }

  .hero__content {
    max-width: 680px;
  }

  /* ── H1 label ── */
  .hero__h1 {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  /* ── Display nadpis ── */
  .hero__display {
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 8vw, 5rem);
    font-weight: 300;
    font-style: normal;
    line-height: 1.0;
    letter-spacing: 0.02em;
    color: #ffffff;
    margin: 0 0 1.25rem;
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
  }

  /* ── Podtext ── */
  .hero__text {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.65);
    margin: 0 0 2.5rem;
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  .hero__text-br { display: none; }
  @media (min-width: 480px) { .hero__text-br { display: inline; } }

  /* ── Actions ── */
  .hero__actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
  }

  /* ── Tlačítko ── */
  .hero__btn-primary {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.4vw, 1.35rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.03em;
    text-decoration: none;
    color: #ffffff;
    background: var(--color-btn);
    padding: 0.9rem 2.25rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  @media (hover: hover) {
    .hero__btn-primary:hover { background: var(--color-btn-hover); }
  }

  /* ── Rating badge ── */
  .hero__reviews {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    text-decoration: none;
    flex-shrink: 0;
    transition: background 0.3s ease;
  }

  @media (hover: hover) {
    .hero__reviews:hover { background: rgba(255, 255, 255, 0.1); }
  }

  .hero__reviews-stars { font-size: 0.72rem; color: var(--color-gold); letter-spacing: 0.06em; line-height: 1; }
  .hero__reviews-divider { width: 1px; height: 0.85rem; background: rgba(255, 255, 255, 0.18); flex-shrink: 0; }
  .hero__reviews-text { font-family: var(--font-body); font-size: 0.78rem; color: rgba(255, 255, 255, 0.55); white-space: nowrap; }
  .hero__reviews-text strong { color: #fff; font-weight: 600; }

  /* ── Desktop: obsah na střed ── */
  @media (min-width: 900px) {
    .hero__container {
      align-items: center;
      text-align: center;
      padding-inline: clamp(1.25rem, 4vw, 3.5rem);
      padding-top: clamp(5rem, 10vw, 8rem);
    }
    .hero__content { max-width: 780px; text-align: center; }
    .hero__h1 { text-align: center; }
    .hero__text { margin-inline: auto; }
    .hero__actions { justify-content: center; flex-direction: column; align-items: center; gap: 1rem; }
  }

  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Wave přechod ── */
  .hero__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    z-index: 3;
    line-height: 0;
  }

  .hero__wave svg {
    display: block;
    width: 100%;
    height: clamp(40px, 6vw, 80px);
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .hero__bg,
    .hero__h1, .hero__display, .hero__text, .hero__actions {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
    .hero__btn-primary, .hero__reviews { transition: none !important; }
  }
</style>

<script>
  const setHeroHeight = () => {
    const hero = document.getElementById('hero');
    if (hero) hero.style.minHeight = `${window.innerHeight}px`;
  };
  let lastWidth = window.innerWidth;
  setHeroHeight();
  window.addEventListener('resize', () => {
    if (window.innerWidth !== lastWidth) { lastWidth = window.innerWidth; setHeroHeight(); }
  });
  window.addEventListener('orientationchange', () => setTimeout(setHeroHeight, 100));

  window.addEventListener('load', () => {
    const video = document.getElementById('heroBg') as HTMLVideoElement;
    if (!video) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      window.dispatchEvent(new Event('lagoon:video-ready'));
      return;
    }

    const source = video.querySelector('source[data-src]') as HTMLSourceElement;
    if (!source) return;

    source.src = source.dataset.src || '';
    // načti i MP4 fallback
    const sources = video.querySelectorAll('source[data-src]') as NodeListOf<HTMLSourceElement>;
    sources.forEach(s => { s.src = s.dataset.src || ''; });
    video.load();
    video.play().catch(() => {});

    const ready = () => {
      video.classList.add('is-loaded');
      window.dispatchEvent(new Event('lagoon:video-ready'));
    };

    video.addEventListener('canplay', ready, { once: true });

    // fallback — max 4s čekání
    setTimeout(() => window.dispatchEvent(new Event('lagoon:video-ready')), 4000);

    document.addEventListener('visibilitychange', () => {
      if (document.visibilityState === 'visible') {
        video.play().catch(() => {});
      }
    });
  });
</script>