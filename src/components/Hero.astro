---
// src/components/Hero.astro
---

<section id="hero" class="hero">
  <picture class="hero__bg">
    <source srcset="/hero-mobile.jpg" media="(max-width: 767px)" />
    <img
      src="/hero.jpg"
      alt="Lagoon Masáže – relaxační prostředí v centru Mladé Boleslavi"
      fetchpriority="high"
      style="width:100%;height:100%;object-fit:cover;display:block;"
    />
  </picture>
  <div class="hero__overlay"></div>

  <div class="hero__container">

    <h1 class="hero__h1">Masáže Mladá Boleslav</h1>

    <p class="hero__display" aria-hidden="true">
      Chvíle klidu<br/>jen pro vás
    </p>

    <p class="hero__text">
      Tradiční orientální techniky, přírodní oleje a tiché prostředí v centru města. Přijďte načerpat energii a odejít lehčí.
    </p>

    <div class="hero__actions">
      <a href="#rezervace" class="hero__btn-primary">Rezervovat termín</a>
      <a href="#typy-masazi" class="hero__btn-ghost">Objevit masáže</a>
    </div>

    <a
      href="https://maps.app.goo.gl/pAcxyPUEK9RcHGYa9"
      target="_blank"
      rel="noopener noreferrer"
      class="hero__reviews"
      aria-label="4,9 hvězdy — 280 recenzí na Google Maps"
    >
      <span class="hero__reviews-stars" aria-hidden="true">★★★★★</span>
      <span class="hero__reviews-divider" aria-hidden="true"></span>
      <span class="hero__reviews-text"><strong>4,9</strong> · 280+ recenzí</span>
    </a>

  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero__bg { position: absolute; inset: 0; z-index: 0; }
  .hero__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.42); z-index: 1; }

  .hero__container {
    position: relative; z-index: 2;
    width: 100%; max-width: 1200px;
    padding: 0 1.25rem;
    padding-top: 6rem;
    display: flex; flex-direction: column;
    align-items: flex-start; text-align: left;
  }

  @media (min-width: 900px) {
    .hero__container {
      align-items: center; text-align: center;
      padding: 0 3.5rem; padding-top: 6rem;
    }
    .hero__text { margin-inline: auto; }
  }

  .hero__h1 {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1.25rem;
    opacity: 0;
    animation: heroFadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }

  .hero__display {
    font-family: var(--font-display);
    font-size: clamp(3.2rem, 7.5vw, 6.5rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.05;
    letter-spacing: 0.01em;
    color: var(--color-white);
    margin: 0 0 0.75rem;
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.25s forwards;
  }

  .hero__text {
    font-family: var(--font-body);
    font-size: clamp(1rem, 1.4vw, 1.15rem);
    font-weight: 300;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.82);
    max-width: 460px;
    margin: 0 0 2.5rem;
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.4s forwards;
  }

  /* ── Akční tlačítka ── */
  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.55s forwards;
  }

  @media (max-width: 540px) {
    .hero__actions { flex-direction: column; width: 100%; }
    .hero__btn-primary,
    .hero__btn-ghost { justify-content: center; }
  }

  .hero__btn-primary {
    font-family: var(--font-display);
    font-size: 1.3rem; font-weight: 400; font-style: italic;
    letter-spacing: 0.04em; text-decoration: none;
    color: var(--color-brown); background: var(--color-gold);
    padding: 0.75rem 2.25rem; border-radius: 999px;
    display: inline-flex; align-items: center;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .hero__btn-primary:hover {
    background: var(--color-white);
  }

  /* Ghost CTA — vylepšený */
  .hero__btn-ghost {
  font-family: var(--font-display);
  font-size: 1.3rem; font-weight: 300; font-style: italic;
  letter-spacing: 0.04em; text-decoration: none;
  color: #ffffff;
  padding: 0.75rem 2.25rem;
  border-radius: 999px;
  border: 1px solid rgba(255, 255, 255, 0.5);
  display: inline-flex; align-items: center;
  transition: border-color 0.3s ease, background 0.3s ease;
}
.hero__btn-ghost:hover {
  border-color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.08);
}

  /* ── Google reviews pill ── */
  .hero__reviews {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    margin-top: 2rem;
    padding: 0.5rem 1.1rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.15);
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    text-decoration: none;
    opacity: 0;
    animation: heroFadeUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.7s forwards;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  .hero__reviews:hover {
    background: rgba(255, 255, 255, 0.11);
    border-color: rgba(255, 255, 255, 0.25);
  }

  .hero__reviews-stars {
    font-size: 0.8rem;
    color: var(--color-gold);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .hero__reviews-divider {
    width: 1px;
    height: 0.9rem;
    background: rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }

  .hero__reviews-text {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
    white-space: nowrap;
  }

  .hero__reviews-text strong {
    color: #fff;
    font-weight: 600;
  }

  /* ── Animace ── */
  @keyframes heroFadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  @keyframes heroFade { to { opacity: 1; } }

  @media (prefers-reduced-motion: reduce) {
    .hero__h1, .hero__display, .hero__text,
    .hero__actions, .hero__reviews { animation: none; opacity: 1; }
  }
</style>

<script>
  const setHeroHeight = () => {
    const hero = document.getElementById('hero');
    if (hero) hero.style.minHeight = `${window.innerHeight}px`;
  };
  let lastWidth = window.innerWidth;
  setHeroHeight();
  window.addEventListener('resize', () => {
    if (window.innerWidth !== lastWidth) { lastWidth = window.innerWidth; setHeroHeight(); }
  });
  window.addEventListener('orientationchange', () => setTimeout(setHeroHeight, 100));
</script>