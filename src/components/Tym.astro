---
// src/components/Tym.astro

const maserky = [
  { jmeno: "Angel",   foto: "/angel.webp" },
  { jmeno: "Jayline", foto: "/jayline.webp" },
  { jmeno: "Rose",    foto: "/rose.webp" },
];
---

<section id="nas-tym" class="tym" aria-labelledby="tym-heading">
  <div class="tym__container">

    <div class="tym__header scroll-animate">
      <span class="tym__eyebrow">Náš tým</span>
      <h2 id="tym-heading" class="tym__title">Seznamte se s&nbsp;masérkami</h2>
    </div>

    <div class="tym__grid">
      {maserky.map((m, i) => (
        <div class="tym__card scroll-animate" style={`transition-delay: ${i * 0.1}s`}>
          <div class="tym__card-photo">
            <img
              src={m.foto}
              alt={m.jmeno}
              width="600"
              height="800"
              loading="lazy"
              decoding="async"
            />
          </div>
          <p class="tym__card-name">{m.jmeno}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .tym {
    background: var(--color-brown);
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .tym__container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 3.5rem);
    display: flex;
    flex-direction: column;
    gap: clamp(3rem, 6vw, 4rem);
  }

  .tym__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .tym__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .tym__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    font-style: normal;
    line-height: 1.05;
    color: #ffffff;
    margin: 0;
  }

  .tym__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1rem, 2vw, 1.75rem);
  }

  @media (max-width: 640px) {
    .tym__grid {
      grid-template-columns: 1fr;
      max-width: 360px;
    }
  }

  .tym__card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .tym__card-photo {
    aspect-ratio: 3 / 4;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow: 0 16px 48px rgba(0, 0, 0, 0.25);
  }

  .tym__card-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    transition: transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @media (hover: hover) {
    .tym__card-photo:hover img { transform: scale(1.04); }
  }

  .tym__card-name {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2vw, 1.6rem);
    font-weight: 400;
    font-style: normal;
    color: #ffffff;
    text-align: center;
  }

  .scroll-animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .tym__card-photo img,
    .scroll-animate {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>