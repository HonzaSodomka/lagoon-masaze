---
// src/components/Recenze.astro

const recenze = [
  {
    jmeno: "Veronika Vágnerová",
    text: "Masérky jsou velmi příjemné a sympatické. Během masáže zjišťují spokojenost a zda je vše v pořádku. Byla jsem již podruhé a pokaždé u jiné masérky — vždy profesionální a odvádějící velmi dobrou práci. Salon čistý, velmi příjemné prostředí.",
  },
  {
    jmeno: "Helena Cardová",
    text: "Klidné, příjemné prostředí — velmi mě to příjemně překvapilo. Masáž naprosto úžasná, filipínská olejová velmi profesionálně provedená. Jsem naprosto spokojená a budu se ráda vracet.",
  },
  {
    jmeno: "Alina Zaychenko",
    text: "Personál je velmi milý, vstřícný a profesionální — hned od příchodu jsem se cítila příjemně. Masáž byla perfektní, přesně taková, jakou jsem potřebovala. Uvolnila mě nejen fyzicky, ale i psychicky. Určitě doporučuji každému, kdo si chce dopřát chvíli opravdového relaxu.",
  },
  {
    jmeno: "Lenka Rousková",
    text: "Filipínská masáž 60 minut byla fantastická — olej jsem si vybrala levandulový, byl krásně teplý. Prostředí působí útulně, mají to tu moc hezky zařízené. Masážní místnost taky moc hezká, líbil se mi strop ověšený květinami. Příjemná zkušenost, určitě se znovu vrátím.",
  },
];
---

<section id="recenze" class="recenze" aria-labelledby="recenze-heading">
  <div class="recenze__container">

    <div class="recenze__header scroll-animate">
      <span class="recenze__eyebrow">Co říkají klienti</span>
      <h2 id="recenze-heading" class="recenze__title">Přes 280 spokojených návštěvníků</h2>
      <div class="recenze__meta">
        <svg class="recenze__google-logo" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-label="Google" width="20" height="20">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
      <span aria-label="5 hvězd" class="recenze__meta-stars">★★★★★</span>
      <span class="recenze__meta-score">4,9 · Google recenze</span>
    </div>
    </div>

    <!-- Desktop: 4 karty -->
    <div class="recenze__grid scroll-animate" style="transition-delay: 0.1s;" aria-label="Recenze zákazníků">
      {recenze.map((r) => (
        <blockquote class="recenze__card">
          <div class="recenze__card-stars" aria-label="5 hvězd">★★★★★</div>
          <p class="recenze__card-text">{r.text}</p>
          <footer class="recenze__card-footer">
            <span class="recenze__card-jmeno">{r.jmeno}</span>
          </footer>
        </blockquote>
      ))}
    </div>

    <!-- Mobil: slider -->
    <div class="recenze__slider scroll-animate" style="transition-delay: 0.1s;" aria-label="Recenze zákazníků">
      <div class="recenze__viewport" id="recenzeViewport">
        <div class="recenze__track" id="recenzeTrack">
          {recenze.map((r, i) => (
            <div class="recenze__slide" aria-label={`Recenze ${i + 1} z ${recenze.length}`}>
              <blockquote class="recenze__card">
                <div class="recenze__card-stars" aria-label="5 hvězd">★★★★★</div>
                <p class="recenze__card-text">{r.text}</p>
                <footer class="recenze__card-footer">
                  <span class="recenze__card-jmeno">{r.jmeno}</span>
                </footer>
              </blockquote>
            </div>
          ))}
        </div>
      </div>
      <div class="recenze__dots" aria-hidden="true" id="recenzeDots">
        {recenze.map((_, i) => (
          <button
            class={`recenze__dot${i === 0 ? ' is-active' : ''}`}
            data-index={String(i)}
            aria-label={`Recenze ${i + 1}`}
          ></button>
        ))}
      </div>
    </div>

    <div class="recenze__cta-wrap scroll-animate" style="transition-delay: 0.2s;">
      <a
        href="https://maps.app.goo.gl/pAcxyPUEK9RcHGYa9"
        target="_blank"
        rel="noopener noreferrer"
        class="recenze__cta"
        aria-label="Přejít na Google recenze"
      >
        Přejít na Google recenze
      </a>
    </div>

  </div>
</section>

<style>
  .recenze {
    background: #2d3d2e;
    padding: clamp(4rem, 8vw, 8rem) 0;
  }

  .recenze__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3.5rem);
  }

  .recenze__header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  @media (min-width: 900px) {
    .recenze__header { align-items: center; text-align: center; }
  }

  .recenze__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .recenze__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    font-style: normal;
    line-height: 1.05;
    color: #ffffff;
    margin: 0 0 1.25rem;
  }

  .recenze__meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .recenze__meta-stars {
    font-size: 1rem;
    color: var(--color-gold);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .recenze__meta-score {
    font-family: var(--font-body);
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.4);
  }

  .recenze__grid {
    display: none;
  }

  @media (min-width: 768px) {
    .recenze__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }

  @media (min-width: 1024px) {
    .recenze__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .recenze__slider {
    display: block;
  }

  @media (min-width: 768px) {
    .recenze__slider { display: none; }
  }

  .recenze__viewport {
    overflow: hidden;
    width: 100%;
    user-select: none;
    -webkit-user-select: none;
  }

  .recenze__track {
    display: flex;
    width: 400%;
    will-change: transform;
  }

  .recenze__slide {
    width: 25%;
    box-sizing: border-box;
    padding: 0 0.25rem;
  }

  .recenze__dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
  }

  .recenze__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: none;
    background: rgba(255, 255, 255, 0.2);
    cursor: pointer;
    padding: 0;
    transition: background 0.25s ease, transform 0.25s ease;
    -webkit-tap-highlight-color: transparent;
  }

  .recenze__dot.is-active {
    background: var(--color-gold);
    transform: scale(1.35);
  }

  .recenze__card {
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 1rem;
    padding: clamp(1.25rem, 3vw, 1.75rem) clamp(1.1rem, 3vw, 1.5rem);
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    box-sizing: border-box;
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  @media (hover: hover) {
    .recenze__card:hover {
      background: rgba(255, 255, 255, 0.11);
      border-color: rgba(255, 255, 255, 0.18);
    }
  }

  .recenze__card-stars {
    font-size: 0.85rem;
    color: var(--color-gold);
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .recenze__card-text {
    font-family: var(--font-body);
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.65);
    margin: 0;
    flex: 1;
  }

  .recenze__card-footer {
    padding-top: 0.875rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-top: auto;
  }

  .recenze__card-jmeno {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 400;
    font-style: normal;
    color: #ffffff;
    line-height: 1.2;
  }

  .recenze__cta-wrap {
    display: flex;
    justify-content: center;
    margin-top: clamp(2.5rem, 4vw, 4rem);
  }

  .recenze__cta {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.03em;
    text-decoration: none;
    color: #ffffff;
    background: var(--color-gold);
    padding: 0.7rem clamp(1.25rem, 2vw, 2rem);
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    white-space: nowrap;
    transition: background 0.3s ease;
  }

  @media (hover: hover) {
    .recenze__cta:hover { background: rgba(198, 162, 122, 0.85); }
  }

  .scroll-animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .scroll-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .recenze__card,
    .recenze__cta,
    .recenze__dot,
    .scroll-animate {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>

<script is:inline>
(function () {
  document.addEventListener('DOMContentLoaded', function () {

    var viewport = document.getElementById('recenzeViewport');
    var track    = document.getElementById('recenzeTrack');
    var dotsEl   = document.getElementById('recenzeDots');
    if (!viewport || !track || !dotsEl) return;

    var dots    = Array.from(dotsEl.querySelectorAll('.recenze__dot'));
    var total   = dots.length;
    var current = 0;

    var touchStartX = 0;
    var touchStartY = 0;
    var touchDeltaX = 0;
    var isSwiping   = false;
    var isDecided   = false;

    function setSlide(index, animate) {
      current = Math.max(0, Math.min(index, total - 1));
      track.style.transition = animate === false
        ? 'none'
        : 'transform 0.38s cubic-bezier(0.25, 1, 0.5, 1)';
      track.style.transform = 'translateX(-' + (current * 25) + '%)';
      dots.forEach(function (d, i) {
        d.classList.toggle('is-active', i === current);
      });
    }

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        setSlide(parseInt(dot.getAttribute('data-index'), 10), true);
      });
    });

    viewport.addEventListener('touchstart', function (e) {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      touchDeltaX = 0;
      isSwiping   = false;
      isDecided   = false;
    }, { passive: true });

    viewport.addEventListener('touchmove', function (e) {
      var dx = e.touches[0].clientX - touchStartX;
      var dy = e.touches[0].clientY - touchStartY;

      if (!isDecided) {
        if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 5) {
          isSwiping = true;
          isDecided = true;
        } else if (Math.abs(dy) > Math.abs(dx) && Math.abs(dy) > 5) {
          isSwiping = false;
          isDecided = true;
        }
      }

      if (!isSwiping) return;

      e.preventDefault();
      touchDeltaX = dx;

      var base   = current * 25;
      var offset = (touchDeltaX / viewport.offsetWidth) * 25;
      track.style.transition = 'none';
      track.style.transform  = 'translateX(-' + (base - offset) + '%)';
    }, { passive: false });

    viewport.addEventListener('touchend', function () {
      if (!isSwiping) return;

      if (touchDeltaX < -50) {
        setSlide(current + 1, true);
      } else if (touchDeltaX > 50) {
        setSlide(current - 1, true);
      } else {
        setSlide(current, true);
      }

      touchDeltaX = 0;
      isSwiping   = false;
      isDecided   = false;
    }, { passive: true });

  });
})();
</script>