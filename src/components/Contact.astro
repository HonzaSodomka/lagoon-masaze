---
// src/components/Contact.astro
import { MapPin, Phone, Mail, Clock } from 'lucide-astro';
---

<section id="kontakt" class="contact" aria-labelledby="contact-heading">
  <div class="contact__container">

    <div class="contact__info scroll-animate">
      <span class="contact__label">Kde nás najdete</span>
      <h2 id="contact-heading" class="contact__heading">Přijďte na&nbsp;místo,<br/>kde se čas zastaví</h2>
      <p class="contact__subtext">
        Najdete nás na Staroměstském náměstí v Mladé Boleslavi vedle Marvel Gymu. Těšíme se na vás.
      </p>

      <ul class="contact__details">
        <li class="contact__detail">
          <span class="contact__detail-icon" aria-hidden="true"><MapPin size={16} /></span>
          <div>
            <span class="contact__detail-label">Adresa</span>
            <a href="https://maps.app.goo.gl/pAcxyPUEK9RcHGYa9" target="_blank" rel="noopener noreferrer" class="contact__detail-value contact__detail-link">
              Staroměstské náměstí 19/23<br/>Mladá Boleslav 293 01
            </a>
          </div>
        </li>

        <li class="contact__detail">
          <span class="contact__detail-icon" aria-hidden="true"><Phone size={16} /></span>
          <div>
            <span class="contact__detail-label">Telefon</span>
            <a href="tel:+420732596212" class="contact__detail-value contact__detail-link">
              +420 732 596 212
            </a>
          </div>
        </li>

        <li class="contact__detail">
          <span class="contact__detail-icon" aria-hidden="true"><Mail size={16} /></span>
          <div>
            <span class="contact__detail-label">E-mail</span>
            <a href="mailto:info@lagoon-masaze.cz" class="contact__detail-value contact__detail-link">
              info@lagoon-masaze.cz
            </a>
          </div>
        </li>

        <li class="contact__detail">
          <span class="contact__detail-icon" aria-hidden="true"><Clock size={16} /></span>
          <div>
            <span class="contact__detail-label">Otevírací doba</span>
            <span class="contact__detail-value">
              Po–So: 8:00 – 20:00<br/>Ne: Zavřeno
            </span>
          </div>
        </li>
      </ul>

      <a href="/rezervace" class="contact__cta" aria-label="Rezervovat termín - přesun na rezervační systém">Rezervovat termín</a>
    </div>

    <div class="contact__visual scroll-animate" style="transition-delay: 0.1s;">

      <div class="contact__photo-wrap">
        <img
          src="/studio.webp"
          alt="Vstup do studia Lagoon Masáže na Staroměstském náměstí v Mladé Boleslavi"
          class="contact__photo"
          loading="lazy"
          width="800"
          height="600"
        />
      </div>

      <div class="contact__divider" aria-hidden="true">
        <span class="contact__divider-line"></span>
        <span class="contact__divider-dot"></span>
        <span class="contact__divider-line"></span>
      </div>

      <div class="contact__map-wrap">
        <div id="map-placeholder" class="contact__map-placeholder">
          <p class="contact__map-placeholder-text">Pro zobrazení mapy je nutný souhlas s cookies.</p>
          <button onclick="(function(){localStorage.setItem('lagoon_cookie_consent', JSON.stringify({maps:true,ts:Date.now()}));var p=document.getElementById('map-placeholder');var i=document.getElementById('map-iframe');if(p)p.style.display='none';if(i)i.style.display='block';var b=document.getElementById('cookie-banner');if(b)b.classList.add('is-hidden');})()" class="contact__map-placeholder-btn">Povolit mapu</button>
        </div>
        <iframe
          id="map-iframe"
          class="contact__map"
          style="display:none; border:0;"
          src="https://www.google.com/maps/embed?pb=!1m14!1m8!1m3!1d2000!2d14.902356641104513!3d50.410201499999985!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x470955551596a721%3A0xe2e014efa9cdcc05!2zTGFnb29uIE1hc8Ohxb5l!5e0!3m2!1scs!2scz!4v1781876501496!5m2!1scs!2scz"
          width="100%" height="100%"
          allowfullscreen="" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa – Lagoon Masáže, Staroměstské náměstí 19/23, Mladá Boleslav"
          aria-label="Mapa – Lagoon Masáže, Staroměstské náměstí 19/23, Mladá Boleslav"
        ></iframe>
      </div>

    </div>
  </div>

  <div class="contact__wave" aria-hidden="true">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
      <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#4A403A"/>
    </svg>
  </div>
</section>

<style>
  /* ── sekce ── */
  .contact {
    background: #ffffff;
    padding-block: clamp(4rem, 8vw, 7rem);
    position: relative;
  }

  .contact__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    z-index: 1;
    line-height: 0;
  }

  .contact__wave svg {
    display: block;
    width: 100%;
    height: clamp(35px, 5vw, 70px);
  }

  .contact__container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 3.5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  @media (max-width: 860px) {
    .contact__container {
      grid-template-columns: 1fr;
    }
    .contact__info   { order: 1; }
    .contact__visual { order: 2; }
  }

  /* ── levý sloupec ── */
  .contact__label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .contact__heading {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    font-style: normal;
    line-height: 1.1;
    color: var(--color-brown);
    margin-bottom: 1rem;
  }

  .contact__subtext {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(74, 64, 58, 0.6);
    max-width: 42ch;
    margin-bottom: 2.5rem;
  }

  .contact__details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .contact__detail {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .contact__detail-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(198, 162, 122, 0.35);
    background: rgba(198, 162, 122, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    margin-top: 0.1rem;
  }

  .contact__detail-icon svg { width: 16px; height: 16px; }

  .contact__detail-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(74, 64, 58, 0.4);
    margin-bottom: 0.2rem;
  }

  .contact__detail-value {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.55;
    color: var(--color-brown);
  }

  .contact__detail-link {
    text-decoration: none;
    transition: color 0.25s ease;
  }

  @media (hover: hover) {
    .contact__detail-link:hover { color: var(--color-gold); }
  }

  .contact__cta {
    font-family: var(--font-display);
    font-size: clamp(1rem, 1.2vw, 1.2rem);
    font-weight: 400;
    font-style: normal;
    letter-spacing: 0.03em;
    text-decoration: none;
    color: #ffffff;
    background: var(--color-btn);
    padding: 0.75rem clamp(1.5rem, 2vw, 2.25rem);
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    white-space: nowrap;
    transition: background 0.3s ease;
  }

  @media (hover: hover) {
    .contact__cta:hover { background: rgba(198, 162, 122, 0.85); }
  }

  /* ── pravý sloupec ── */
  .contact__visual {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* fotka */
  .contact__photo-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 1.25rem 1.25rem 0 0;
    overflow: hidden;
    border: 1px solid rgba(74, 64, 58, 0.08);
    border-bottom: none;
    box-shadow: 0 8px 32px rgba(74, 64, 58, 0.07);
  }

  .contact__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  @media (hover: hover) {
    .contact__photo-wrap:hover .contact__photo {
      transform: scale(1.04);
    }
  }

  /* oddělovač */
  .contact__divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-inline: 0.25rem;
    background: #ffffff;
    border-inline: 1px solid rgba(74, 64, 58, 0.08);
    padding-block: 0.85rem;
  }

  .contact__divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(198, 162, 122, 0.0),
      rgba(198, 162, 122, 0.4),
      rgba(198, 162, 122, 0.0)
    );
  }

  .contact__divider-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-gold);
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* mapa */
  .contact__map-wrap {
    height: clamp(180px, 25vw, 240px);
    border-radius: 0 0 1.25rem 1.25rem;
    overflow: hidden;
    border: 1px solid rgba(74, 64, 58, 0.08);
    border-top: none;
    box-shadow: 0 8px 32px rgba(74, 64, 58, 0.07);
  }

  .contact__map {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Cookie placeholder ── */
  .contact__map-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    background: rgba(74, 64, 58, 0.04);
    border-radius: 0 0 1.25rem 1.25rem;
  }

  .contact__map-placeholder-text {
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: rgba(74, 64, 58, 0.5);
    text-align: center;
    padding: 0 1rem;
  }

  .contact__map-placeholder-btn {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: normal;
    color: #ffffff;
    background: var(--color-btn);
    border: none;
    padding: 0.55rem 1.4rem;
    border-radius: 999px;
    cursor: pointer;
    transition: background 0.25s ease;
  }

  @media (hover: hover) {
    .contact__map-placeholder-btn:hover {
      background: rgba(198, 162, 122, 0.85);
    }
  }

  /* ── SCROLL ANIMACE ── */
  .scroll-animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── REDUCED MOTION ── */
  @media (prefers-reduced-motion: reduce) {
    .contact__photo,
    .contact__cta,
    .scroll-animate {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>