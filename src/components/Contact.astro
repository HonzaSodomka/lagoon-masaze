---
// src/components/Contact.astro
---

<section id="kontakt" class="contact">
  <div class="contact__container">

    <!-- ── levý sloupec: info ── -->
    <div class="contact__info">
      <span class="contact__label">Kontakt</span>
      <h2 class="contact__heading">Přijďte na&nbsp;místo,<br/>kde se čas zastaví</h2>
      <p class="contact__subtext">
        Najdete nás na Staroměstském náměstí v Mladé Boleslavi, vedle Marvel Gymu. Těšíme se na vás.
      </p>

      <ul class="contact__details">
        <li class="contact__detail">
          <span class="contact__detail-icon"><i data-lucide="map-pin"></i></span>
          <div>
            <span class="contact__detail-label">Adresa</span>
            <a href="https://maps.app.goo.gl/pAcxyPUEK9RcHGYa9" target="_blank" rel="noopener noreferrer" class="contact__detail-value contact__detail-link">
              Staroměstské náměstí 19/23<br/>Mladá Boleslav 293 01
            </a>
          </div>
        </li>

        <li class="contact__detail">
          <span class="contact__detail-icon"><i data-lucide="phone"></i></span>
          <div>
            <span class="contact__detail-label">Telefon</span>
            <a href="tel:+420776381199" class="contact__detail-value contact__detail-link">
              +420 776 381 199
            </a>
          </div>
        </li>

        <li class="contact__detail">
          <span class="contact__detail-icon"><i data-lucide="mail"></i></span>
          <div>
            <span class="contact__detail-label">E-mail</span>
            <a href="mailto:info@lagoon-masaze.cz" class="contact__detail-value contact__detail-link">
              info@lagoon-masaze.cz
            </a>
          </div>
        </li>

        <li class="contact__detail">
          <span class="contact__detail-icon"><i data-lucide="clock"></i></span>
          <div>
            <span class="contact__detail-label">Otevírací doba</span>
            <span class="contact__detail-value">
              Po–Pá: 9:00 – 20:00<br/>So–Ne: 10:00 – 18:00
            </span>
          </div>
        </li>
      </ul>

      <a href="#rezervace" class="contact__cta">Rezervovat termín</a>
    </div>

    <!-- ── pravý sloupec: fotka + mapa ── -->
    <div class="contact__visual">

      <!-- Fotka studia -->
      <div class="contact__photo-wrap">
        <img
          src="/studio.webp"
          alt="Interiér studia Lagoon Masáže"
          class="contact__photo"
          loading="lazy"
          width="800"
          height="600"
        />
      </div>

      <!-- Delikátní oddělovač -->
      <div class="contact__divider" aria-hidden="true">
        <span class="contact__divider-line"></span>
        <span class="contact__divider-dot"></span>
        <span class="contact__divider-line"></span>
      </div>

      <!-- Mapa -->
      <div class="contact__map-wrap">
        <iframe
          class="contact__map"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2000!2d14.90247369690523!3d50.41018080615023!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTDCsDI0JzM2LjciTiAxNMKwNTQnMDguOSJF!5e0!3m2!1scs!2scz!4v1"
          width="100%" height="100%"
          style="border:0;" allowfullscreen="" loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa – Lagoon Masáže, Staroměstské náměstí 19/23, Mladá Boleslav"
        ></iframe>
      </div>

    </div>
  </div>
</section>

<style>
  /* ── sekce ── */
  .contact {
    background: var(--color-bg);
    padding-block: clamp(4rem, 8vw, 7rem);
  }

  .contact__container {
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 3.5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  /* ── levý sloupec ── */
  .contact__label {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .contact__heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.1;
    color: var(--color-brown);
    margin-bottom: 1rem;
  }

  .contact__subtext {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.65;
    color: rgba(74, 64, 58, 0.6);
    max-width: 42ch;
    margin-bottom: 2.5rem;
  }

  .contact__details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .contact__detail {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
  }

  .contact__detail-icon {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(198, 162, 122, 0.35);
    background: rgba(198, 162, 122, 0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-gold);
    margin-top: 0.1rem;
  }

  .contact__detail-icon i { width: 16px; height: 16px; }

  .contact__detail-label {
    display: block;
    font-family: var(--font-body);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(74, 64, 58, 0.4);
    margin-bottom: 0.2rem;
  }

  .contact__detail-value {
    display: block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 300;
    line-height: 1.55;
    color: var(--color-brown);
  }

  .contact__detail-link {
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .contact__detail-link:hover { color: var(--color-gold); }

  .contact__cta {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0.04em;
    text-decoration: none;
    color: var(--color-brown);
    background: var(--color-gold);
    padding: 0.75rem 2.25rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    transition: background 0.3s ease, color 0.3s ease;
  }
  .contact__cta:hover { background: var(--color-brown); color: #fff; }

  /* ── pravý sloupec ── */
  .contact__visual {
    display: flex;
    flex-direction: column;
    gap: 0; /* gap řídí divider */
  }

  /* fotka */
  .contact__photo-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    border-radius: 1.25rem 1.25rem 0 0;
    overflow: hidden;
    border: 1px solid rgba(74, 64, 58, 0.08);
    border-bottom: none;
    box-shadow: 0 8px 32px rgba(74, 64, 58, 0.07);
  }

  .contact__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .contact__photo-wrap:hover .contact__photo {
    transform: scale(1.04);
  }

  /* tmavý přechod dole + badge */
  .contact__photo-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      transparent 55%,
      rgba(44, 36, 30, 0.45) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 1.25rem 1.5rem;
    pointer-events: none;
  }

  .contact__photo-badge {
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: rgba(255, 255, 255, 0.75);
  }

  /* oddělovač */
  .contact__divider {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-inline: 0.25rem;
    background: var(--color-bg);
    border-inline: 1px solid rgba(74, 64, 58, 0.08);
    padding-block: 0.85rem;
  }

  .contact__divider-line {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      to right,
      rgba(198, 162, 122, 0.0),
      rgba(198, 162, 122, 0.4),
      rgba(198, 162, 122, 0.0)
    );
  }

  .contact__divider-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-gold);
    opacity: 0.6;
    flex-shrink: 0;
  }

  /* mapa */
  .contact__map-wrap {
    height: 240px;
    border-radius: 0 0 1.25rem 1.25rem;
    overflow: hidden;
    border: 1px solid rgba(74, 64, 58, 0.08);
    border-top: none;
    box-shadow: 0 8px 32px rgba(74, 64, 58, 0.07);
  }

  .contact__map {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── responzivita ── */
  @media (max-width: 860px) {
    .contact__container {
      grid-template-columns: 1fr;
    }

    .contact__info   { order: 1; }
    .contact__visual { order: 2; }

    .contact__photo-wrap {
      border-radius: 1.25rem 1.25rem 0 0;
    }

    .contact__map-wrap {
      height: 200px;
    }
  }
</style>