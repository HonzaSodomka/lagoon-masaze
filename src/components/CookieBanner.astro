---
---

<div id="cookie-banner" class="cookie-banner" role="dialog" aria-label="Nastavení cookies" aria-live="polite">
  <div class="cookie-banner__inner">
    <div class="cookie-banner__text">
      <p class="cookie-banner__title">Tento web používá cookies</p>
      <p class="cookie-banner__desc">
        Používáme cookies třetích stran pro zobrazení mapy Google Maps. 
        Více informací v <a href="/zasady-ochrany-soukromi" class="cookie-banner__link">zásadách ochrany soukromí</a>.
      </p>
    </div>
    <div class="cookie-banner__actions">
      <button id="cookie-settings" class="cookie-banner__btn cookie-banner__btn--ghost">Nastavení</button>
      <button id="cookie-reject" class="cookie-banner__btn cookie-banner__btn--ghost">Odmítnout vše</button>
      <button id="cookie-accept" class="cookie-banner__btn cookie-banner__btn--primary">Přijmout vše</button>
    </div>
  </div>
</div>

<div id="cookie-modal" class="cookie-modal" role="dialog" aria-modal="true" aria-label="Podrobné nastavení cookies" aria-hidden="true">
  <div class="cookie-modal__box">
    <p class="cookie-modal__title">Nastavení cookies</p>

    <div class="cookie-modal__item">
      <div class="cookie-modal__item-text">
        <span class="cookie-modal__item-name">Nezbytné cookies</span>
        <span class="cookie-modal__item-desc">Zajišťují základní fungování webu. Nelze vypnout.</span>
      </div>
      <span class="cookie-modal__always">Vždy aktivní</span>
    </div>

    <div class="cookie-modal__item">
      <div class="cookie-modal__item-text">
        <span class="cookie-modal__item-name">Mapové služby (Google Maps)</span>
        <span class="cookie-modal__item-desc">Umožňují zobrazení interaktivní mapy s polohou studia.</span>
      </div>
      <label class="cookie-modal__toggle" aria-label="Povolit mapové služby">
        <input type="checkbox" id="cookie-maps" />
        <span class="cookie-modal__toggle-track"></span>
      </label>
    </div>

    <div class="cookie-modal__actions">
      <button id="cookie-save" class="cookie-banner__btn cookie-banner__btn--primary">Uložit nastavení</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 2.5rem);
    max-width: 860px;
    background: var(--color-brown);
    border-radius: 1rem;
    padding: clamp(1rem, 3vw, 1.25rem) clamp(1rem, 3vw, 1.5rem);
    z-index: 999;
    box-shadow: 0 8px 32px rgba(0,0,0,0.18);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .cookie-banner.is-hidden {
    opacity: 0;
    transform: translateX(-50%) translateY(20px);
    pointer-events: none;
  }

  .cookie-banner__inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cookie-banner__text {
    flex: 1;
    min-width: 200px;
  }

  .cookie-banner__title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-style: italic;
    font-weight: 400;
    color: #ffffff;
    margin-bottom: 0.25rem;
  }

  .cookie-banner__desc {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.5;
    margin: 0;
  }

  .cookie-banner__link {
    color: var(--color-gold);
    text-decoration: underline;
    text-decoration-color: rgba(198,162,122,0.4);
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  @media (hover: hover) {
    .cookie-banner__link:hover { color: #ffffff; }
  }

  .cookie-banner__actions {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    flex-shrink: 0;
    width: 100%;
    justify-content: center;
  }

  .cookie-banner__btn {
    font-family: var(--font-display);
    font-size: 1rem;
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0.03em;
    padding: 0.55rem 1.4rem;
    border-radius: 999px;
    border: none;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .cookie-banner__btn--primary {
    background: var(--color-gold);
    color: var(--color-brown);
  }

  @media (hover: hover) {
    .cookie-banner__btn--primary:hover {
      background: #ffffff;
      color: var(--color-brown);
    }
    .cookie-modal__actions .cookie-banner__btn--primary:hover {
      background: var(--color-brown);
      color: #ffffff;
    }
  }

  .cookie-banner__btn--ghost {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.75);
    border: 1px solid rgba(255,255,255,0.15);
  }

  @media (hover: hover) {
    .cookie-banner__btn--ghost:hover {
      background: rgba(255,255,255,0.15);
      color: #ffffff;
    }
  }

  @media (max-width: 600px) {
    .cookie-banner__inner {
      flex-direction: column;
      align-items: flex-start;
    }

    .cookie-banner__actions {
      width: 100%;
      display: grid;
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      gap: 0.5rem;
      justify-items: center;
    }

    #cookie-settings { grid-column: 1; grid-row: 1; }
    #cookie-reject   { grid-column: 2; grid-row: 1; }

    #cookie-accept {
      grid-column: 1 / -1;
      grid-row: 2;
      text-align: center;
      width: 100%;
    }
  }

  @media (max-width: 360px) {
    .cookie-banner__actions {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto auto;
    }

    #cookie-settings { grid-column: 1; grid-row: 1; width: 100%; }
    #cookie-reject   { grid-column: 1; grid-row: 2; width: 100%; }
    #cookie-accept   { grid-column: 1; grid-row: 3; width: 100%; }

    .cookie-banner__btn {
      width: 100%;
      text-align: center;
      justify-content: center;
      display: flex;
    }
  }

  /* Modal */
  .cookie-modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    background: rgba(44,36,30,0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1.25rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .cookie-modal.is-open {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
  }

  .cookie-modal__box {
    background: #ffffff;
    border-radius: 1rem;
    padding: clamp(1.25rem, 4vw, 2rem);
    max-width: 480px;
    width: 100%;
  }

  .cookie-modal__title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-style: italic;
    font-weight: 300;
    color: var(--color-brown);
    margin-bottom: 1.5rem;
  }

  .cookie-modal__item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 0;
    border-bottom: 1px solid rgba(74,64,58,0.08);
  }

  .cookie-modal__item:last-of-type {
    border-bottom: none;
  }

  .cookie-modal__item-text {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .cookie-modal__item-name {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-brown);
  }

  .cookie-modal__item-desc {
    font-family: var(--font-body);
    font-size: 0.8rem;
    color: rgba(74,64,58,0.55);
    line-height: 1.5;
    max-width: 30ch;
  }

  .cookie-modal__always {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-gold);
    white-space: nowrap;
  }

  /* Toggle switch */
  .cookie-modal__toggle {
    position: relative;
    flex-shrink: 0;
    cursor: pointer;
  }

  .cookie-modal__toggle input {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .cookie-modal__toggle-track {
    display: block;
    width: 44px;
    height: 24px;
    background: rgba(74,64,58,0.2);
    border-radius: 999px;
    position: relative;
    transition: background 0.25s ease;
  }

  .cookie-modal__toggle-track::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #ffffff;
    transition: transform 0.25s ease;
  }

  .cookie-modal__toggle input:checked + .cookie-modal__toggle-track {
    background: var(--color-gold);
  }

  .cookie-modal__toggle input:checked + .cookie-modal__toggle-track::after {
    transform: translateX(20px);
  }

  .cookie-modal__toggle input:focus-visible + .cookie-modal__toggle-track {
    outline: 2px solid var(--color-gold);
    outline-offset: 2px;
  }

  .cookie-modal__actions {
    margin-top: 1.5rem;
    display: flex;
    justify-content: flex-end;
  }

  .cookie-modal__actions .cookie-banner__btn--primary {
    color: var(--color-brown);
  }

  @media (prefers-reduced-motion: reduce) {
    .cookie-banner,
    .cookie-modal { transition: none !important; }
  }
</style>

<script is:inline>
(function () {
  var STORAGE_KEY = 'lagoon_cookie_consent';

  var banner      = document.getElementById('cookie-banner');
  var modal       = document.getElementById('cookie-modal');
  var btnAccept   = document.getElementById('cookie-accept');
  var btnReject   = document.getElementById('cookie-reject');
  var btnSettings = document.getElementById('cookie-settings');
  var btnSave     = document.getElementById('cookie-save');
  var chkMaps     = document.getElementById('cookie-maps');

  function getConsent() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY)); } catch(e) { return null; }
  }

  function saveConsent(maps) {
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ maps: maps, ts: Date.now() }));
  }

  function hideBanner() {
    banner.classList.add('is-hidden');
  }

  function applyConsent(maps) {
    var placeholder = document.getElementById('map-placeholder');
    var iframe      = document.getElementById('map-iframe');
    if (!placeholder || !iframe) return;
    if (maps) {
      placeholder.style.display = 'none';
      iframe.style.display      = 'block';
    } else {
      placeholder.style.display = 'flex';
      iframe.style.display      = 'none';
    }
  }

  var FOCUSABLE = 'a[href], button:not([disabled]), input, [tabindex]:not([tabindex="-1"])';
  var trapHandler = null;

  function openModal() {
    var consent = getConsent();
    if (consent) chkMaps.checked = consent.maps;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');

    var focusable = Array.from(modal.querySelectorAll(FOCUSABLE));
    if (focusable.length) focusable[0].focus();

    trapHandler = function(e) {
      if (e.key === 'Escape') {
        closeModal();
        return;
      }
      if (e.key !== 'Tab') return;
      var first = focusable[0];
      var last  = focusable[focusable.length - 1];
      if (e.shiftKey) {
        if (document.activeElement === first) { e.preventDefault(); last.focus(); }
      } else {
        if (document.activeElement === last)  { e.preventDefault(); first.focus(); }
      }
    };
    document.addEventListener('keydown', trapHandler);
  }

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    if (trapHandler) { document.removeEventListener('keydown', trapHandler); trapHandler = null; }
  }

  function init() {
    var consent = getConsent();
    if (consent !== null) {
      hideBanner();
      applyConsent(consent.maps);
      return;
    }
    banner.classList.remove('is-hidden');
  }

  btnAccept.addEventListener('click', function () {
    saveConsent(true);
    applyConsent(true);
    hideBanner();
  });

  btnReject.addEventListener('click', function () {
    saveConsent(false);
    applyConsent(false);
    hideBanner();
  });

  btnSettings.addEventListener('click', openModal);

  btnSave.addEventListener('click', function () {
    saveConsent(chkMaps.checked);
    applyConsent(chkMaps.checked);
    closeModal();
    hideBanner();
  });

  modal.addEventListener('click', function (e) {
    if (e.target === modal) closeModal();
  });

  // Globální event — otvírá modal odkudkoliv (např. z Footeru)
  document.addEventListener('lagoon:open-cookie-modal', openModal);

  init();
})();
</script>