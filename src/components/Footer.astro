---
// src/components/Footer.astro
const year = new Date().getFullYear();
import { Instagram, Facebook } from 'lucide-astro';
---

<footer class="footer" role="contentinfo">
  <div class="footer__container">
    
    <div class="scroll-animate">
      
      <div class="footer__top">
        <div class="footer__brand">
          <a href="/" class="footer__logo" aria-label="Zpět na hlavní stranu">
            <img src="/logo.png" alt="" width="160" height="89" loading="eager" />
          </a>
          <p class="footer__legal">
            IČ: 193 25 240<br/>
            Společnost je zapsaná u Městského soudu v Praze pod spisovou značkou C 384783
          </p>
        </div>

        <nav class="footer__links-col" aria-label="Patičková navigace">
          <h3 class="footer__heading">Menu</h3>
          <ul class="footer__list">
            <li><a href="#typy-masazi" class="footer__link">Typy masáží</a></li>
            <li><a href="#jak-to-funguje" class="footer__link">Jak to funguje</a></li>
            <li><a href="#kontakt" class="footer__link">Kontakt</a></li>
            <li><a href="#rezervace" class="footer__link footer__link--gold" aria-label="Rezervovat termín - přesun na rezervační systém">Rezervovat termín</a></li>
          </ul>
        </nav>

        <div class="footer__contact-col">
          <h3 class="footer__heading">Lagoon Masáže</h3>
          <ul class="footer__list">
            <li class="footer__text">Staroměstské náměstí 19/23<br/>Mladá Boleslav 293 01</li>
            <li><a href="tel:+420732596212" class="footer__link" aria-label="Zavolejte nám">+420 732 596 212</a></li>
            <li><a href="mailto:info@lagoon-masaze.cz" class="footer__link" aria-label="Napište nám e-mail">info@lagoon-masaze.cz</a></li>
            <li class="footer__social">
  <a href="https://www.instagram.com/lagoon_masaze" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="Lagoon Masáže na Instagramu">
    <Instagram size={18} />
  </a>
  <a href="https://www.facebook.com/p/Lagoon-Mas%C3%A1%C5%BEe-61553022234305/" target="_blank" rel="noopener noreferrer" class="footer__social-link" aria-label="Lagoon Masáže na Facebooku">
    <Facebook size={18} />
  </a>
</li>
          </ul>
        </div>
      </div>

      <div class="footer__bottom">
        <p class="footer__copy">&copy; {year} Lagoon Masáže. Všechna práva vyhrazena.</p>
        <div class="footer__bottom-links">
          <a href="/zasady-ochrany-soukromi" class="footer__cookie-btn">Zásady ochrany soukromí</a>
          <span class="footer__bottom-sep" aria-hidden="true">·</span>
          <button id="footer-cookie-settings" class="footer__cookie-btn" aria-label="Změnit nastavení cookies">Nastavení cookies</button>
        </div>
        <p class="footer__credits">
          Realizováno <a href="https://webresent.cz" target="_blank" rel="noopener noreferrer" class="footer__webresent">Webresent</a>
        </p>
      </div>

    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-brown);
    padding: clamp(4rem, 8vw, 6rem) 0 2rem;
    color: #ffffff;
    overflow: hidden;
  }

  .footer__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.25rem;
  }

  @media (min-width: 900px) {
    .footer__container { padding: 0 3.5rem; }
  }

  /* ── Horní mřížka ── */
  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    margin-bottom: clamp(3rem, 6vw, 4rem);
  }

  @media (min-width: 768px) {
    .footer__top {
      grid-template-columns: 2fr 1fr 1.5fr;
      gap: 2rem;
    }
  }

  /* ── Brand ── */
  .footer__logo {
    display: inline-block;
    margin-bottom: 1.5rem;
    transition: opacity 0.3s ease;
  }
  
  @media (hover: hover) {
    .footer__logo:hover { opacity: 0.8; }
  }
  
  .footer__logo img {
    display: block;
    width: clamp(140px, 15vw, 180px);
  }

  .footer__legal {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.5);
    max-width: 40ch;
  }

  /* ── Sloupce s odkazy a kontaktem ── */
  .footer__heading {
    font-family: var(--font-display);
    font-size: 1.3rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-gold);
    margin-bottom: 1.25rem;
  }

  .footer__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer__text {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.7);
  }

  .footer__link {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s ease;
  }
  
  .footer__link--gold {
    color: var(--color-gold);
    font-weight: 500;
  }

  @media (hover: hover) {
    .footer__link:hover { color: #ffffff; }
    .footer__link--gold:hover { color: #ffffff; }
  }

  /* ── Spodní lišta ── */
  .footer__bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    padding-top: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
    text-align: center;
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
  }

  @media (min-width: 600px) {
    .footer__bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }

  /* ── Spodní odkazy ── */
  .footer__bottom-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    white-space: nowrap;
  }

  .footer__bottom-sep {
    color: rgba(255, 255, 255, 0.2);
    font-size: 1rem;
  }

  .footer__cookie-btn {
    font-family: var(--font-body);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: none;
    transition: color 0.3s ease;
    white-space: nowrap;
  }

  @media (hover: hover) {
    .footer__cookie-btn:hover { color: var(--color-gold); }
  }

  .footer__webresent {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.3s ease;
  }
  
  @media (hover: hover) {
    .footer__webresent:hover { color: var(--color-gold); }
  }

  /* ── SCROLL ANIMACE ── */
  .scroll-animate {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 1s cubic-bezier(0.16, 1, 0.3, 1), transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .scroll-animate.is-visible {
    opacity: 1;
    transform: translateY(0);
  }
.footer__social {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-top: 0.25rem;
}

.footer__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid rgba(255, 255, 255, 0.15);
  color: rgba(255, 255, 255, 0.5);
  transition: border-color 0.3s ease, color 0.3s ease;
}

@media (hover: hover) {
  .footer__social-link:hover {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }
}
  /* ── REDUCED MOTION ── */
  @media (prefers-reduced-motion: reduce) {
    .footer__link,
    .footer__logo,
    .footer__webresent,
    .footer__cookie-btn,
    .scroll-animate {
      transition: none !important;
      transform: none !important;
      opacity: 1 !important;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.scroll-animate').forEach(function(el) {
      observer.observe(el);
    });

    var cookieBtn = document.getElementById('footer-cookie-settings');
    if (cookieBtn) {
      cookieBtn.addEventListener('click', function () {
        var modal = document.getElementById('cookie-modal');
        if (modal) {
          modal.classList.add('is-open');
          modal.setAttribute('aria-hidden', 'false');
        }
      });
    }
  });
</script>