---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import {
  VolumeX, CalendarCheck, ShowerHead, Toilet,
  Video, Phone
} from 'lucide-astro';
---

<Layout
  title="Jak to u nás funguje | Lagoon Masáže Mladá Boleslav"
  description="Vše, co potřebujete vědět před návštěvou Lagoon Masáže — od rezervace přes příchod až po závěr masáže."
  forceScrolledNavbar={true}
>

<section class="jtf-hero" id="jtf-hero">

  <div class="jtf-hero__carousel" aria-label="Fotografie studia Lagoon Masáže">
    <div class="jtf-hero__track" id="heroTrack">
      <div class="jtf-hero__slide is-active">
        <picture>
          <source media="(max-width: 767px)" srcset="/recepceJTF1-mob.webp" />
          <img src="/recepceJTF1.webp" alt="Recepce Lagoon Masáže" width="800" height="600" loading="eager" decoding="async" />
        </picture>
      </div>
      <div class="jtf-hero__slide">
        <picture>
          <source media="(max-width: 767px)" srcset="/interierJTF-mob.webp" />
          <img src="/interierJTF.webp" alt="Masážní místnost v Lagoon Masáže" width="800" height="600" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="jtf-hero__slide">
        <picture>
          <source media="(max-width: 767px)" srcset="/recepceJTF2-mob.webp" />
          <img src="/recepceJTF2.webp" alt="Prostor recepce Lagoon Masáže" width="800" height="600" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="jtf-hero__slide">
        <picture>
          <source media="(max-width: 767px)" srcset="/interierJTF2-mob.webp" />
          <img src="/interierJTF2.webp" alt="Druhá masážní místnost v Lagoon Masáže" width="800" height="600" loading="lazy" decoding="async" />
        </picture>
      </div>
      <div class="jtf-hero__slide">
        <picture>
          <source media="(max-width: 767px)" srcset="/studioJTF-mob.webp" />
          <img src="/studioJTF.webp" alt="Studio Lagoon Masáže na Staroměstském náměstí" width="800" height="600" loading="lazy" decoding="async" />
        </picture>
      </div>
    </div>

    <div class="jtf-hero__dots" aria-hidden="true">
      <button class="jtf-hero__dot is-active" data-index="0"></button>
      <button class="jtf-hero__dot" data-index="1"></button>
      <button class="jtf-hero__dot" data-index="2"></button>
      <button class="jtf-hero__dot" data-index="3"></button>
      <button class="jtf-hero__dot" data-index="4"></button>
    </div>

    <button class="jtf-hero__arrow jtf-hero__arrow--prev" id="heroPrev" aria-label="Předchozí fotografie">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg>
    </button>
    <button class="jtf-hero__arrow jtf-hero__arrow--next" id="heroNext" aria-label="Další fotografie">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg>
    </button>
  </div>

  <div class="jtf-hero__container">
    <div class="jtf-hero__text scroll-animate">
      <span class="jtf-hero__eyebrow">Průvodce návštěvou</span>
      <h1 class="jtf-hero__title">Jak to u&nbsp;nás funguje</h1>
      <p class="jtf-hero__sub">Vše, co potřebujete vědět před první i každou další návštěvou.</p>
    </div>
  </div>

  <div class="jtf-wave" aria-hidden="true">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#f5f0ea"/></svg>
  </div>
</section>

<section class="jtf-steps" aria-label="Kroky návštěvy">
  <div class="jtf-steps__container">

    <div class="jtf-steps__header scroll-animate">
      <span class="jtf-steps__eyebrow">Krok za krokem</span>
      <h2 class="jtf-steps__title">Vaše návštěva</h2>
      <p class="jtf-steps__subtitle">Sedm kroků od rezervace po šálek čaje na závěr.</p>
    </div>

    <ol class="jtf-steps__list">

      <li class="jtf-steps__item scroll-animate">
        <div class="jtf-steps__num" aria-hidden="true">01</div>
        <div class="jtf-steps__body">
          <h3 class="jtf-steps__name">Rezervace</h3>
          <p class="jtf-steps__text">Vše začíná výběrem termínu a&nbsp;masáže. Nejsnazší cesta je přes náš online rezervační systém — vyberete typ, délku a&nbsp;případně přidáte poznámku. Hodí se zmínit cokoliv, co by masérka měla vědět předem — zdravotní omezení, preference nebo zvláštní přání.</p>
          <p class="jtf-steps__text">Nejde to online? Zavolejte na <a href="tel:+420732596212" class="jtf-steps__link">+420&nbsp;732&nbsp;596&nbsp;212</a> nebo napište na <a href="mailto:info@lagoon-masaze.cz" class="jtf-steps__link">info@lagoon-masaze.cz</a>.</p>
        </div>
      </li>

      <li class="jtf-steps__item scroll-animate" style="transition-delay:0.05s">
        <div class="jtf-steps__num" aria-hidden="true">02</div>
        <div class="jtf-steps__body">
          <h3 class="jtf-steps__name">SMS s&nbsp;kódem</h3>
          <p class="jtf-steps__text">Po rezervaci obdržíte potvrzovací e-mail. 24&nbsp;hodin předem vám přijde SMS — a&nbsp;v&nbsp;ní kód od vstupních dveří, díky kterému se dostanete přímo do recepce bez čekání.</p>
        </div>
      </li>

      <li class="jtf-steps__item scroll-animate" style="transition-delay:0.1s">
        <div class="jtf-steps__num" aria-hidden="true">03</div>
        <div class="jtf-steps__body">
          <h3 class="jtf-steps__name">Parkování</h3>
          <p class="jtf-steps__text">Jsme na Staroměstském náměstí — velmi frekventované místo. Přímo na náměstí je podzemní parkovací dům, kde místo téměř vždy najdete. Počítejte ale i tak s mírnou časovou rezervou.</p>
        </div>
      </li>

      <li class="jtf-steps__item scroll-animate" style="transition-delay:0.15s">
        <div class="jtf-steps__num" aria-hidden="true">04</div>
        <div class="jtf-steps__body">
          <h3 class="jtf-steps__name">Přijďte s&nbsp;předstihem</h3>
          <p class="jtf-steps__text">Masáž je o&nbsp;relaxaci, ne o&nbsp;stresu. Doporučujeme dorazit klidně 15&nbsp;minut předem. Váš časový blok je pevný — z&nbsp;ohledu na ostatní klienty ho nelze prodloužit.</p>
        </div>
      </li>

      <li class="jtf-steps__item scroll-animate" style="transition-delay:0.2s">
        <div class="jtf-steps__num" aria-hidden="true">05</div>
        <div class="jtf-steps__body">
          <h3 class="jtf-steps__name">Recepce</h3>
          <p class="jtf-steps__text">Po zadání kódu vstoupíte do recepce — čeká na vás čaj, káva nebo malý snack. Nalaďte se v klidu na masáž a vyčkejte zde na masérku. WC najdete na konci chodby.</p>
        </div>
      </li>

      <li class="jtf-steps__item scroll-animate" style="transition-delay:0.25s">
        <div class="jtf-steps__num" aria-hidden="true">06</div>
        <div class="jtf-steps__body">
          <h3 class="jtf-steps__name">Průběh masáže</h3>
          <p class="jtf-steps__text">Masérka vás vyzvedne a doprovodí do místnosti. Sundáte si boty a nasadíte pantofle — osobní věci si vezměte s sebou. Jakmile budete připraveni, masérka zaklepe a začínáme. Nebojte se říct, pokud vám něco nevyhovuje — tlak, tempo, cokoliv.</p>
        </div>
      </li>

      <li class="jtf-steps__item scroll-animate" style="transition-delay:0.3s">
        <div class="jtf-steps__num" aria-hidden="true">07</div>
        <div class="jtf-steps__body">
          <h3 class="jtf-steps__name">Na závěr</h3>
          <p class="jtf-steps__text">Platba probíhá na recepci po skončení masáže. Chcete-li nechat spropitné, je v&nbsp;místnosti připravená nádoba. Po masáži si dopřejte čaj nebo kávu — klid po masáži je stejně důležitý jako masáž samotná.</p>
        </div>
      </li>

    </ol>

  </div>
</section>

<section class="jtf-rules" aria-label="Pravidla salonu">

  <div class="jtf-rules__intro">
    <div class="jtf-rules__intro-img scroll-animate">
      <img src="/maserky.webp" alt="Masérky Lagoon Masáže" width="800" height="600" loading="lazy" decoding="async" />
    </div>
    <div class="jtf-rules__intro-text scroll-animate" style="transition-delay:0.1s">
      <span class="jtf-rules__eyebrow">Pravidla salonu</span>
      <h2 class="jtf-rules__title">Aby se dobře cítili všichni</h2>
      <p class="jtf-rules__sub">Pár věcí, které pomáhají udržet Lagoon tím, čím je — klidným místem pro každého.</p>
    </div>
  </div>

  <div class="jtf-rules__container">
    <div class="jtf-rules__grid">

      <div class="jtf-rules__card scroll-animate" style="transition-delay:0.05s">
        <div class="jtf-rules__card-icon" aria-hidden="true"><VolumeX size={22} /></div>
        <h3 class="jtf-rules__card-title">Ticho jako součást rituálu</h3>
        <p class="jtf-rules__card-text">Jsme místem klidu a relaxace. Buďte prosím během čekání na recepci potichu, abyste nerušili ostatní klienty.</p>
      </div>

      <div class="jtf-rules__card scroll-animate" style="transition-delay:0.1s">
        <div class="jtf-rules__card-icon" aria-hidden="true"><CalendarCheck size={22} /></div>
        <h3 class="jtf-rules__card-title">Jen s&nbsp;rezervací</h3>
        <p class="jtf-rules__card-text">Bez rezervace vás nepřijmeme. Pokud máte zájem o masáž, proveďte prosím rezervaci předem přes náš web.</p>
      </div>

      <div class="jtf-rules__card scroll-animate" style="transition-delay:0.15s">
        <div class="jtf-rules__card-icon" aria-hidden="true"><ShowerHead size={22} /></div>
        <h3 class="jtf-rules__card-title">Osobní hygiena</h3>
        <p class="jtf-rules__card-text">Přijďte čistí. Masáž je práce s přímým kontaktem těla a dbáme na komfort obou stran.</p>
      </div>

      <div class="jtf-rules__card scroll-animate" style="transition-delay:0.2s">
        <div class="jtf-rules__card-icon" aria-hidden="true"><Toilet size={22} /></div>
        <h3 class="jtf-rules__card-title">Pouze toaletní papír</h3>
        <p class="jtf-rules__card-text">Do záchodové mísy patří jen toaletní papír. Nic jiného tam prosím nevhazujte.</p>
      </div>

      <div class="jtf-rules__card scroll-animate" style="transition-delay:0.25s">
        <div class="jtf-rules__card-icon" aria-hidden="true"><Video size={22} /></div>
        <h3 class="jtf-rules__card-title">Kamerový systém</h3>
        <p class="jtf-rules__card-text">Recepce je monitorována kamerou — kvůli bezpečí vás i našich zaměstnanců. Masážní místnosti kamerou vybaveny nejsou.</p>
      </div>

      <div class="jtf-rules__card scroll-animate" style="transition-delay:0.3s">
        <div class="jtf-rules__card-icon" aria-hidden="true"><Phone size={22} /></div>
        <h3 class="jtf-rules__card-title">Cokoliv nevyhovuje, řekněte</h3>
        <p class="jtf-rules__card-text">Něco nesedělo nebo máte otázku? Zavolejte. Rádi vám s čímkoliv pomůžeme.</p>
        <a href="tel:+420732596212" class="jtf-rules__tel">+420&nbsp;732&nbsp;596&nbsp;212</a>
      </div>

    </div>

    <div class="jtf-rules__cta scroll-animate">
      <p class="jtf-rules__cta-label">Teď víte vše.<br/>Zbývá si vybrat masáž.</p>
      <a href="/rezervace" class="jtf-rules__cta-btn">Rezervovat termín</a>
    </div>
  </div>

  <div class="jtf-wave jtf-wave--bottom" aria-hidden="true">
    <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none"><path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#4A403A"/></svg>
  </div>
</section>

<Footer />

</Layout>

<style>
.jtf-wave {
  position: absolute;
  bottom: -1px; left: 0;
  width: 100%; line-height: 0; z-index: 1;
}
.jtf-wave svg {
  display: block; width: 100%;
  height: clamp(35px, 5vw, 70px);
}

/* HERO */
.jtf-hero {
  background: var(--color-brown);
  position: relative;
  display: flex;
  align-items: flex-end;
  min-height: 100dvh;
  overflow: hidden;
  padding-bottom: clamp(5rem, 10vw, 8rem);
}

.jtf-hero__carousel {
  position: absolute;
  inset: 0;
  z-index: 0;
  overflow: hidden;
  background: var(--color-brown);
}

.jtf-hero__carousel::after {
  content: '';
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background:
    linear-gradient(to right, rgba(74,64,58,0.92) 0%, rgba(74,64,58,0.65) 40%, rgba(74,64,58,0.25) 100%),
    linear-gradient(to top, rgba(74,64,58,0.82) 0%, transparent 45%);
}

.jtf-hero__track {
  position: absolute;
  inset: 0;
}

.jtf-hero__slide {
  position: absolute;
  inset: 0;
  opacity: 0;
  transition: opacity 0.7s ease;
  pointer-events: none;
}

.jtf-hero__slide.is-active {
  opacity: 1;
  pointer-events: auto;
}

.jtf-hero__slide img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

.jtf-hero__dots {
  position: absolute;
  bottom: 1.75rem;
  right: 2rem;
  left: auto;
  transform: none;
  display: flex; gap: 0.45rem;
  z-index: 2;
}

.jtf-hero__dot {
  width: 6px; height: 6px; border-radius: 50%;
  border: none; background: rgba(255,255,255,.3);
  cursor: pointer; padding: 0;
  transition: background 0.25s ease, transform 0.25s ease;
  -webkit-tap-highlight-color: transparent;
}

.jtf-hero__dot.is-active {
  background: #fff;
  transform: scale(1.4);
}

.jtf-hero__arrow {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  z-index: 2;
  width: 44px; height: 44px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,.18);
  background: rgba(255,255,255,.07);
  backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
  color: #fff;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: background 0.25s ease, border-color 0.25s ease;
  -webkit-tap-highlight-color: transparent;
}

.jtf-hero__arrow--prev { left: 1.5rem; }
.jtf-hero__arrow--next { right: 1.5rem; }

@media (hover: hover) {
  .jtf-hero__arrow:hover {
    background: rgba(255,255,255,.16);
    border-color: rgba(255,255,255,.35);
  }
}

.jtf-hero__container {
  position: relative;
  z-index: 2;
  max-width: 1200px;
  width: 100%;
  margin-inline: auto;
  padding-inline: clamp(1.25rem, 4vw, 3.5rem);
}

.jtf-hero__text {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  max-width: 620px;
}

.jtf-hero__eyebrow {
  display: block;
  font-family: var(--font-body);
  font-size: 0.75rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.2em;
  color: var(--color-gold); margin-bottom: 1rem;
}

.jtf-hero__title {
  font-family: var(--font-display);
  font-size: clamp(3rem, 6vw, 5.5rem);
  font-weight: 300; line-height: 1.0;
  color: #fff; margin: 0 0 1.25rem;
}

.jtf-hero__sub {
  font-family: var(--font-body);
  font-size: 1.05rem; line-height: 1.7;
  color: rgba(255,255,255,.65);
  max-width: 44ch; margin: 0;
}

/* KROKY */
.jtf-steps {
  background: #f5f0ea;
  padding-top: clamp(4rem, 8vw, 7rem);
  padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
  position: relative;
}

.jtf-steps__container {
  max-width: 800px;
  margin-inline: auto;
  padding-inline: clamp(1.25rem, 4vw, 3.5rem);
}

.jtf-steps__header {
  display: flex; flex-direction: column;
  align-items: flex-start; text-align: left;
  margin-bottom: clamp(3rem, 6vw, 5rem);
}

@media (min-width: 900px) {
  .jtf-steps__header { align-items: center; text-align: center; }
  .jtf-steps__subtitle { margin-inline: auto; }
}

.jtf-steps__eyebrow {
  display: block;
  font-family: var(--font-body);
  font-size: 0.75rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.2em;
  color: var(--color-gold); margin-bottom: 1rem;
}

.jtf-steps__title {
  font-family: var(--font-display);
  font-size: clamp(2.2rem, 4vw, 3.25rem);
  font-weight: 300; line-height: 1.05;
  color: var(--color-brown); margin: 0 0 0.75rem;
}

.jtf-steps__subtitle {
  font-family: var(--font-body);
  font-size: 1rem; line-height: 1.65;
  color: rgba(74,64,58,.72); margin: 0;
}

.jtf-steps__list {
  list-style: none; padding: 0; margin: 0;
  display: flex; flex-direction: column;
  position: relative;
}

.jtf-steps__list::before {
  content: '';
  position: absolute;
  left: 1.5rem;
  top: 2rem;
  bottom: 2rem;
  width: 1px;
  background: linear-gradient(
    to bottom,
    transparent,
    rgba(198,162,122,0.35) 8%,
    rgba(198,162,122,0.35) 92%,
    transparent
  );
  pointer-events: none;
}

.jtf-steps__item {
  display: grid;
  grid-template-columns: 3rem 1fr;
  gap: 0 clamp(1rem, 2.5vw, 1.5rem);
  align-items: flex-start;
  padding-block: clamp(1.75rem, 3.5vw, 2.5rem);
  border-bottom: 1px solid rgba(74,64,58,.07);
}

.jtf-steps__item:first-child { border-top: 1px solid rgba(74,64,58,.07); }

.jtf-steps__num {
  justify-self: center;
  width: 2.25rem;
  height: 2.25rem;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  border: 1px solid rgba(198,162,122,0.45);
  background: #f5f0ea;
  position: relative;
  z-index: 1;
  font-family: var(--font-body);
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  color: var(--color-gold);
  user-select: none;
  margin-top: 0.1em;
  flex-shrink: 0;
}

.jtf-steps__body { min-width: 0; }

.jtf-steps__name {
  font-family: var(--font-display);
  font-size: clamp(1.2rem, 1.8vw, 1.5rem);
  font-weight: 400; line-height: 1.2;
  color: var(--color-brown); margin: 0 0 0.65rem;
}

.jtf-steps__text {
  font-family: var(--font-body);
  font-size: 0.95rem; line-height: 1.8;
  color: rgba(74,64,58,.75); margin: 0 0 0.5rem;
}

.jtf-steps__text:last-child { margin-bottom: 0; }

.jtf-steps__link {
  color: var(--color-gold);
  text-decoration: underline;
  text-decoration-color: rgba(198,162,122,.4);
  text-underline-offset: 3px; white-space: nowrap;
  transition: color 0.2s ease, text-decoration-color 0.2s ease;
}

@media (hover: hover) {
  .jtf-steps__link:hover {
    color: var(--color-brown);
    text-decoration-color: rgba(74,64,58,.4);
  }
}

/* PRAVIDLA */
.jtf-rules {
  background: #f5f0ea;
  padding-top: clamp(3rem, 6vw, 5rem);
  padding-bottom: clamp(5rem, 10vw, 8rem);
  position: relative;
}

.jtf-rules__intro {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  margin-bottom: clamp(3rem, 6vw, 5rem);
  padding-inline: clamp(1.25rem, 4vw, 3.5rem);
}

@media (min-width: 860px) {
  .jtf-rules__intro {
    grid-template-columns: 1fr 1fr;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(1.25rem, 4vw, 3.5rem);
  }
}

.jtf-rules__intro-img {
  position: relative;
  border-radius: 1.25rem;
  overflow: hidden;
  aspect-ratio: 4 / 3;
  background: rgba(0,0,0,.2);
  order: 2;
}

@media (min-width: 860px) {
  .jtf-rules__intro-img {
    order: 1;
    aspect-ratio: auto;
    max-height: 460px;
  }
  .jtf-rules__intro-text { order: 2; }
}

.jtf-rules__intro-img img {
  width: 100%; height: 100%;
  object-fit: cover; object-position: center 30%;
  display: block;
}

.jtf-rules__intro-text {
  display: flex; flex-direction: column;
  justify-content: center; align-items: flex-start;
  padding: clamp(2.5rem, 6vw, 5rem) clamp(1.5rem, 5vw, 4rem);
}

.jtf-rules__eyebrow {
  display: block;
  font-family: var(--font-body);
  font-size: 0.75rem; font-weight: 600;
  text-transform: uppercase; letter-spacing: 0.2em;
  color: var(--color-gold); margin-bottom: 1rem;
}

