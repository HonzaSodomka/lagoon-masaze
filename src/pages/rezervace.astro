---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Rezervace masáže | Lagoon Masáže Mladá Boleslav"
  description="Rezervujte si masáž online. Vyberte typ masáže, termín a potvrďte rezervaci — rychle a jednoduše."
>
  <script is:inline>
    document.documentElement.classList.add('navbar-force-scrolled');
  </script>

  <style is:global>
    .navbar-force-scrolled #navbar {
      background: #ffffff !important;
      box-shadow: 0 1px 0 rgba(74, 64, 58, 0.08) !important;
    }
    .navbar-force-scrolled #navbar .navbar__logo-white { opacity: 0 !important; }
    .navbar-force-scrolled #navbar .navbar__logo-dark  { opacity: 1 !important; }
    .navbar-force-scrolled #navbar .navbar__link       { color: var(--color-brown) !important; }
    .navbar-force-scrolled #navbar .navbar__dot        { color: rgba(74, 64, 58, 0.25) !important; }
    .navbar-force-scrolled #navbar .navbar__hamburger span { background: var(--color-brown) !important; }

    /* iframe styling — reenio ho vkládá dynamicky */
    .rezervace__widget iframe {
      border-radius: 1.25rem !important;
      box-shadow:
        0 4px 6px rgba(74, 64, 58, 0.04),
        0 12px 40px rgba(74, 64, 58, 0.10) !important;
      overflow: hidden;
    }
  </style>

  <Navbar />

  <section class="rezervace">
    <div class="rezervace__container">

      <div class="rezervace__header">
        <span class="rezervace__eyebrow">Online rezervace</span>
        <h1 class="rezervace__title">Vyberte si termín</h1>
        <p class="rezervace__subtitle">Rezervujte si masáž online. Po rezervaci obdržíte potvrzovací e-mail a 24 hodin předem SMS s kódem od dveří.</p>
      </div>

      <div class="rezervace__widget">
        <div class="reenio-iframe" data-size="auto"></div>
        <script src="https://reenio.cz/cs/GE2DMMRU/widget-iframe.js" async defer></script>
      </div>

    </div>
  </section>

  <Footer />
</Layout>

<style>
  .rezervace {
    background: #f5f0ea;
    padding-top: clamp(8rem, 16vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 6rem);
    min-height: 100dvh;
  }

  .rezervace__container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3.5rem);
  }

  .rezervace__header {
    text-align: center;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  .rezervace__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .rezervace__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 300;
    font-style: italic;
    line-height: 1.05;
    color: var(--color-brown);
    margin: 0 0 1rem;
  }

  .rezervace__subtitle {
    font-family: var(--font-body);
    font-size: clamp(0.95rem, 1.2vw, 1.05rem);
    font-weight: 300;
    line-height: 1.65;
    color: rgba(74, 64, 58, 0.6);
    max-width: 52ch;
    margin: 0 auto;
  }

  .rezervace__widget {
    width: 100%;
    /* fallback pokud iframe selector nefunguje */
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow:
      0 4px 6px rgba(74, 64, 58, 0.04),
      0 12px 40px rgba(74, 64, 58, 0.10);
  }
</style>