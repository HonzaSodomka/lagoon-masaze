---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Rezervace masáže | Lagoon Masáže Mladá Boleslav"
  description="Rezervujte si masáž online. Vyberte typ masáže, termín a potvrďte rezervaci — rychle a jednoduše."
  forceScrolledNavbar={true}
>
  <style is:global>
    /* iframe styling — reenio ho vkládá dynamicky */
    .rezervace__widget iframe {
      border-radius: 1.25rem !important;
      box-shadow:
        0 4px 6px rgba(74, 64, 58, 0.04),
        0 12px 40px rgba(74, 64, 58, 0.10) !important;
      overflow: hidden;
    }
  </style>

  <section class="rezervace">
    <div class="rezervace__container">

      <div class="rezervace__header">
        <span class="rezervace__eyebrow">Online rezervace</span>
        <h1 class="rezervace__title">Vyberte si svou masáž</h1>
        <p class="rezervace__subtitle">Rezervujte si masáž online. Po rezervaci obdržíte potvrzovací e-mail a 24 hodin předem SMS s kódem od dveří.</p>
      </div>

      <div class="rezervace__widget">
        <div class="reenio-iframe" data-size="auto"></div>
        <script src="https://reenio.cz/cs/GE2DMMRU/widget-iframe.js" async defer></script>
      </div>

    </div>

    <div class="rezervace__wave" aria-hidden="true">
      <svg viewBox="0 0 1440 70" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none">
        <path d="M0,35 C360,70 1080,0 1440,35 L1440,70 L0,70 Z" fill="#4A403A"/>
      </svg>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  .rezervace {
    background: #f5f0ea;
    padding-top: clamp(8rem, 16vw, 12rem);
    padding-bottom: clamp(4rem, 8vw, 6rem);
    min-height: 100dvh;
    position: relative;
  }

  .rezervace__wave {
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 100%;
    z-index: 1;
    line-height: 0;
  }

  .rezervace__wave svg {
    display: block;
    width: 100%;
    height: clamp(35px, 5vw, 70px);
  }

  .rezervace__container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 clamp(1.25rem, 4vw, 3.5rem);
  }

  .rezervace__header {
    text-align: left;
    margin-bottom: clamp(3rem, 6vw, 5rem);
  }

  @media (min-width: 900px) {
    .rezervace__header { text-align: center; }
    .rezervace__subtitle { margin-inline: auto; }
  }

  .rezervace__eyebrow {
    display: block;
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--color-gold);
    margin-bottom: 1rem;
  }

  .rezervace__title {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 4vw, 3.25rem);
    font-weight: 300;
    font-style: normal;
    line-height: 1.05;
    color: var(--color-brown);
    margin: 0 0 1rem;
  }

  .rezervace__subtitle {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.65;
    color: rgba(74, 64, 58, 0.72);
    max-width: 52ch;
    margin: 0 auto;
  }

  .rezervace__widget {
    width: 100%;
    border-radius: 1.25rem;
    overflow: hidden;
    box-shadow:
      0 4px 6px rgba(74, 64, 58, 0.04),
      0 12px 40px rgba(74, 64, 58, 0.10);
  }
</style>